{
  "name": "agro-trade-native",
  "private": true,
  "workspaces": [
    "backend",
    "front-end",
    "contracts",
    "contracts-solana",
    "admin-dashboard",
    "landing"
  ],
  "scripts": {
    "prepare": "husky || true",
    "lint": "eslint . --ext .ts,.tsx,.js --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml}\"",
    "typecheck": "tsc --noEmit -p tsconfig.base.json"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "docx": "^9.6.1"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
