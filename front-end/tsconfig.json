{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "src",
    "verbatimModuleSyntax": false,
    "paths": {
      "@screens/*": ["screens/*"],
      "@shared/*": ["shared/*"],
      "@navigation/*": ["navigation/*"],
      "@stores/*": ["stores/*"],
      "@services/*": ["services/*"],
      "@assets/*": ["assets/*"],
      "@styles/*": ["styles/*"],
      "@contexts/*": ["contexts/*"],
      "@features/*": ["features/*"],
      "@design-system": ["design-system"],
      "@design-system/*": ["design-system/*"]
    }
  },
  "include": [
    "src/**/*",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}