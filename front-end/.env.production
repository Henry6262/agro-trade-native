# Production Environment Variables for Frontend

# API Configuration
# Update this with your actual deployed backend API URL
EXPO_PUBLIC_API_URL=https://be-agro-trade-native.vercel.app/api

# Google Maps API Key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=${GOOGLE_MAPS_API_KEY}

# App Configuration
EXPO_PUBLIC_APP_NAME=AgroTrade
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_ENVIRONMENT=production

# Frontend App URL (for OAuth callbacks)
EXPO_PUBLIC_APP_URL=https://agro-trade.vercel.app