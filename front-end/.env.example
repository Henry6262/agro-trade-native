# API Configuration
# For local development: http://localhost:4000/api
# For production: https://your-backend-url.vercel.app/api
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Google Maps API Key (required for location services)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Privy Authentication
# Get these from https://dashboard.privy.io/
# Production values (update for your environment):
EXPO_PUBLIC_PRIVY_APP_ID=cmieakfr201g9jo0cwewfvsgi
EXPO_PUBLIC_PRIVY_CLIENT_ID=client-WY6TLwqxXyDiAPyNeScsFaAszjDAVQb5SUaExWLvEQv1n

# App Configuration
EXPO_PUBLIC_APP_NAME=AgroTrade
EXPO_PUBLIC_APP_VERSION=1.0.0

# Environment Configuration
# Options: development, staging, production
EXPO_PUBLIC_ENVIRONMENT=production

# Optional: Analytics and monitoring
# EXPO_PUBLIC_ANALYTICS_KEY=your_analytics_key
# EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Market Intelligence
# Commodity prices use Yahoo Finance — no API key required (parallel fetches, ~1-2s load time)
# Market Intelligence — GNews (free): https://gnews.io/
EXPO_PUBLIC_GNEWS_KEY=your_gnews_key_here
