{
  "expo": {
    "name": "AgroTrade",
    "slug": "agro-trade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.agrotrade.app",
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyCyufA02eE2szI8_Q2DSxIa5AabNSik3MA"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to help you add warehouse and storage locations for your agricultural products.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location to show nearby bases and optimize delivery routes."
      }
    },
    "android": {
      "package": "com.agrotrade.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCyufA02eE2szI8_Q2DSxIa5AabNSik3MA"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "agrotrade",
    "plugins": [
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "organization": "agrotrade",
          "project": "react-native"
        }
      ],
      "expo-secure-store"
    ],
    "owner": "henry6262",
    "extra": {
      "eas": {
        "projectId": "9a2f3b44-4a6b-49e4-a05a-83c3f0a864db"
      }
    },
    "hooks": {
      "postPublish": [
        {
          "file": "sentry-expo/upload-sourcemaps",
          "config": {
            "organization": "agrotrade",
            "project": "react-native"
          }
        }
      ]
    }
  }
}
