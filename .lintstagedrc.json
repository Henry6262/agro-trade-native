{
  "*.{ts,tsx}": [
    "eslint --fix --max-warnings=0",
    "prettier --write"
  ],
  "*.{js,mjs,cjs}": [
    "eslint --fix --max-warnings=0",
    "prettier --write"
  ],
  "*.{json,md,yml,yaml}": [
    "prettier --write"
  ],
  "backend/**/*.{ts,js}": [
    "bash -c 'cd backend && npx tsc --noEmit --project tsconfig.json'"
  ],
  "front-end/**/*.{ts,tsx}": [
    "bash -c 'cd front-end && npx tsc --noEmit --project tsconfig.json'"
  ],
  "contracts/**/*.{ts,js}": [
    "bash -c 'cd contracts && npx tsc --noEmit --project tsconfig.json'"
  ],
  "contracts-solana/**/*.{ts,js}": [
    "bash -c 'cd contracts-solana && npx tsc --noEmit --project tsconfig.json'"
  ]
}
