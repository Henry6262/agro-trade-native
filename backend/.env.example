# Application
NODE_ENV=development
PORT=3000
APP_NAME=agro-trade-backend
APP_URL=http://localhost:3000

# Database - Prisma Postgres from Vercel
# For local development, you can use a local PostgreSQL instance
# For production, use the Prisma Postgres URLs from Vercel dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/agrotrade?schema=public"

# Prisma Accelerate URL (optional - for connection pooling and edge caching)
# PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
# Note: Callback URL is dynamically constructed from APP_URL as: ${APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Privy Authentication
PRIVY_APP_ID=your-privy-app-id

# Payment
# NOTE: This project does NOT use Stripe. Payments are handled exclusively via
# Celo cUSD on-chain escrow (see BLOCKCHAIN section below) and USDC on Solana.
# Do NOT attempt to integrate Stripe — it is not part of the architecture.

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DESTINATION=./uploads

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@agro-trade.com

# Cloudinary (Optional for image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Platform Configuration
COMMISSION_PERCENTAGE=5
DEFAULT_CURRENCY=USD
DEFAULT_LANGUAGE=en

# Frontend URLs
CLIENT_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# Blockchain / Escrow (Celo Sepolia testnet)
ESCROW_CONTRACT_ADDRESS=
BLOCKCHAIN_RPC_URL=https://alfajores-forno.celo-testnet.org
ADMIN_WALLET_PRIVATE_KEY=
ADMIN_WALLET_ADDRESS=
CUSD_TOKEN_ADDRESS=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1

# ---------------------------------------------------------------------------
# EU Regulatory Track — Project Grain Sovereign
# ---------------------------------------------------------------------------

# EBSI (European Blockchain Services Infrastructure)
# Your DID is generated during EBSI onboarding (see docs/eu-strategy/EBSI_TRUSTED_ISSUER_FR_DE_ROADMAP.md).
# For local dev, use the testnet placeholder below. For production, replace with your registered DID.
EBSI_ISSUER_DID=did:ebsi:zf39q7d8PLACEHOLDER_REPLACE_AFTER_ONBOARDING

# EBSI Trusted Issuers Registry endpoint. Leave default for pilot/testnet.
EBSI_TIR_ENDPOINT=https://api-pilot.ebsi.eu/trusted-issuers-registry/v4

# B2G (Business-to-Government) Data API
# Comma-separated list of API keys for public-sector access to aggregated trade data.
# Generate strong random keys and rotate quarterly. Add DG AGRI / BLE keys here.
B2G_API_KEYS=agro_b2g_741ce5f465e9f75fee7f5c79471d00a9149be4da5ec0668e06bc424cd83a84a8
