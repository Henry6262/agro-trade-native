// Simplified Agro Trade Schema - MVP User Onboarding
// Version: 1.0 (Minimal)
// Focus: User authentication and progressive profile completion

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  FARMER
  BUYER
  TRANSPORTER
  ADMIN
}

enum TruckType {
  FLATBED
  TANKER
  REEFER
  OTHER
}

enum ProductCategory {
  WHEAT
  CORN
  SUNFLOWER
  BARLEY
  OATS
  RAPESEED
  PEAS
  SOYBEAN_MEAL
  WHEAT_BRAN
  ALFALFA
  OTHER
}

enum ProductUnit {
  TON
  KG
}

enum ProductStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum DocumentType {
  ID_CARD
  BUSINESS_LICENSE
  VAT_CERT
  INSURANCE
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== CORE TABLES ====================

// 1. Users - Core authentication and identity
model User {
  id        String   @id @default(cuid())
  googleId  String?  @unique @map("google_id")
  email     String   @unique
  name      String?
  phone     String?
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  farmerProfile      FarmerProfile?
  buyerProfile       BuyerProfile?
  transporterProfile TransporterProfile?
  companyInfo        CompanyInfo?
  trucks             Truck[]
  products           Product[]
  documents          KycDocument[]
  fleetVehicles      FleetVehicle[]
  transporterBases   TransporterBase[] @relation("TransporterBases")

  @@map("users")
}

// 2. Role-based Profiles

model FarmerProfile {
  userId         String  @id @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  farmName       String? @map("farm_name")
  locationAddress String? @map("location_address")
  locationLat    Float?  @map("location_lat")
  locationLng    Float?  @map("location_lng")
  businessId     String? @map("business_id") // VAT/license number
  iban           String?
  certifications Json?   // Array of certification names
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("farmer_profiles")
}

model BuyerProfile {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String? @map("company_name")
  vatId           String? @map("vat_id")
  billingAddress  Json?   @map("billing_address") // {street, city, state, zip, country}
  paymentMethod   Json?   @map("payment_method")  // {type, details}
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("buyer_profiles")
}

model TransporterProfile {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String? @map("company_name")
  licenseNumber   String? @map("license_number")
  baseLocationAddress String? @map("base_location_address")
  baseLocationLat Float?  @map("base_location_lat")
  baseLocationLng Float?  @map("base_location_lng")
  insuranceDocUrl String? @map("insurance_doc_url")
  iban            String?
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("transporter_profiles")
}

// Company Information for enhanced registration flow
model CompanyInfo {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String  @map("company_name")
  vatNumber       String? @map("vat_number")
  businessLicense String? @map("business_license")
  companyAddress  Json?   @map("company_address") // {street, city, state, zip, country}
  website         String?
  establishedYear Int?    @map("established_year")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("company_info")
}

// Multiple base locations for transporters
model TransporterBase {
  id            String  @id @default(cuid())
  transporterId String  @map("transporter_id")
  user          User    @relation("TransporterBases", fields: [transporterId], references: [id], onDelete: Cascade)
  
  name          String  // Base name/identifier
  address       String
  latitude      Float
  longitude     Float
  isPrimary     Boolean @default(false) @map("is_primary")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([transporterId])
  @@map("transporter_bases")
}

// Enhanced fleet vehicle information for transporters
model FleetVehicle {
  id            String    @id @default(cuid())
  transporterId String    @map("transporter_id")
  transporter   User      @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  
  plateNumber   String    @map("plate_number")
  vehicleType   TruckType @map("vehicle_type")
  capacityKg    Int       @map("capacity_kg")
  year          Int?
  make          String?
  model         String?
  fuelType      String?   @map("fuel_type") // DIESEL, GASOLINE, etc.
  active        Boolean   @default(true)
  
  // Documentation
  registrationDoc String? @map("registration_doc")
  insuranceDoc    String? @map("insurance_doc")
  licenseDoc      String? @map("license_doc")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([transporterId])
  @@map("fleet_vehicles")
}

// 3. Assets

model Truck {
  id            String    @id @default(cuid())
  transporterId String    @map("transporter_id")
  transporter   User      @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  
  plateNumber   String    @map("plate_number")
  capacityKg    Int       @map("capacity_kg")
  type          TruckType
  active        Boolean   @default(true)
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([transporterId])
  @@map("trucks")
}

model Product {
  id            String          @id @default(cuid())
  farmerId      String          @map("farmer_id")
  farmer        User            @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  
  category      ProductCategory
  quantity      Decimal         @db.Decimal(10, 2)
  unit          ProductUnit
  locationAddress String?       @map("location_address")
  locationLat   Float?          @map("location_lat")
  locationLng   Float?          @map("location_lng")
  status        ProductStatus   @default(AVAILABLE)
  
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([farmerId])
  @@index([status])
  @@map("products")
}

// 4. Compliance (Optional at MVP)

model KycDocument {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  docType     DocumentType       @map("doc_type")
  docUrl      String             @map("doc_url")
  status      VerificationStatus @default(PENDING)
  submittedAt DateTime           @default(now()) @map("submitted_at")
  reviewedAt  DateTime?          @map("reviewed_at")
  reviewNotes String?            @map("review_notes")

  @@index([userId])
  @@index([status])
  @@map("kyc_documents")
}