// ==================== REGIONAL PRICING SYSTEM ====================

// Countries we operate in
model Country {
  id           String   @id @default(cuid())
  name         String   @unique // Bulgaria, Greece
  code         String   @unique // BG, GR
  flagEmoji    String   @map("flag_emoji") // 🇧🇬, 🇬🇷
  currencyCode String   @map("currency_code") // BGN, EUR
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  regions      Region[]
  
  @@map("countries")
}

// Administrative regions/states within countries
model Region {
  id        String   @id @default(cuid())
  countryId String   @map("country_id")
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  
  name      String   // Sofia Oblast, Plovdiv Oblast, Attica, Macedonia
  code      String?  // Optional region code
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  cities    City[]
  
  @@unique([countryId, name])
  @@index([countryId])
  @@map("regions")
}

// Cities with coordinates
model City {
  id         String   @id @default(cuid())
  regionId   String   @map("region_id")
  region     Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  
  name       String   // Sofia, Plovdiv, Athens, Thessaloniki
  latitude   Float
  longitude  Float
  population Int?     // Optional population data
  isCapital  Boolean  @default(false) @map("is_capital")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  
  pricingZones CityPricingZone[]
  userLocationProfiles UserLocationProfile[]
  
  @@unique([regionId, name])
  @@index([regionId])
  @@index([latitude, longitude])
  @@map("cities")
}

// Logical pricing zones (can group multiple cities)
model PricingZone {
  id          String   @id @default(cuid())
  name        String   @unique // Sofia Metro, Northern Bulgaria, Southern Greece
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(0) // Higher priority zones take precedence
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  cities         CityPricingZone[]
  productPrices  ProductPrice[]
  seasonalPricing SeasonalPricing[]
  marketConditions MarketCondition[]
  
  @@index([isActive])
  @@map("pricing_zones")
}

// Junction table: Many cities can belong to many pricing zones
model CityPricingZone {
  cityId        String      @map("city_id")
  city          City        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  pricingZoneId String      @map("pricing_zone_id")
  pricingZone   PricingZone @relation(fields: [pricingZoneId], references: [id], onDelete: Cascade)
  
  isPrimary     Boolean     @default(false) @map("is_primary") // Primary zone for the city
  createdAt     DateTime    @default(now()) @map("created_at")
  
  @@id([cityId, pricingZoneId])
  @@index([cityId])
  @@index([pricingZoneId])
  @@map("city_pricing_zones")
}

// Product prices per zone with date ranges
model ProductPrice {
  id            String      @id @default(cuid())
  productId     String      @map("product_id")
  product       ProductCatalog @relation(fields: [productId], references: [id], onDelete: Cascade)
  pricingZoneId String      @map("pricing_zone_id")
  pricingZone   PricingZone @relation(fields: [pricingZoneId], references: [id], onDelete: Cascade)
  
  minPrice      Decimal     @map("min_price") @db.Decimal(10, 2)
  maxPrice      Decimal     @map("max_price") @db.Decimal(10, 2)
  avgPrice      Decimal?    @map("avg_price") @db.Decimal(10, 2) // Optional average/recommended price
  currency      String      @default("EUR") // EUR, BGN
  
  effectiveDate DateTime    @default(now()) @map("effective_date")
  expiresDate   DateTime?   @map("expires_date")
  
  confidence    Float?      // Price confidence score (0-1)
  source        String?     // Data source for the price
  notes         String?     @db.Text
  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  createdBy     String?     @map("created_by") // Admin user who set the price
  
  @@unique([productId, pricingZoneId, effectiveDate])
  @@index([productId, pricingZoneId])
  @@index([effectiveDate, expiresDate])
  @@map("product_prices")
}

// Seasonal price adjustments
model SeasonalPricing {
  id            String      @id @default(cuid())
  productId     String      @map("product_id")
  product       ProductCatalog @relation(fields: [productId], references: [id], onDelete: Cascade)
  pricingZoneId String      @map("pricing_zone_id")
  pricingZone   PricingZone @relation(fields: [pricingZoneId], references: [id], onDelete: Cascade)
  
  season        String      // Spring, Summer, Fall, Winter
  startMonth    Int         @map("start_month") // 1-12
  endMonth      Int         @map("end_month") // 1-12
  priceMultiplier Float     @map("price_multiplier") // 1.2 = 20% increase
  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  
  @@unique([productId, pricingZoneId, season])
  @@index([productId, pricingZoneId])
  @@map("seasonal_pricing")
}

// Market conditions affecting prices
model MarketCondition {
  id            String      @id @default(cuid())
  pricingZoneId String      @map("pricing_zone_id")
  pricingZone   PricingZone @relation(fields: [pricingZoneId], references: [id], onDelete: Cascade)
  
  date          DateTime    @default(now())
  supplyLevel   Float       @map("supply_level") // 0-1 scale (0=shortage, 1=surplus)
  demandLevel   Float       @map("demand_level") // 0-1 scale (0=low, 1=high)
  weatherImpact String?     @map("weather_impact") // drought, flood, normal, excellent
  
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  
  @@unique([pricingZoneId, date])
  @@index([pricingZoneId])
  @@index([date])
  @@map("market_conditions")
}

// User location profiles for pricing
model UserLocationProfile {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Current location
  cityId        String?  @map("city_id")
  city          City?    @relation(fields: [cityId], references: [id])
  
  // Manual address if no city match
  manualAddress String?  @map("manual_address")
  latitude      Float?
  longitude     Float?
  
  // Location detection method
  detectionMethod String? @map("detection_method") // auto, manual, ip-based
  accuracy      Float?    // Location accuracy in meters
  
  // Preferences
  preferredCurrency String? @map("preferred_currency")
  notifyPriceChanges Boolean @default(true) @map("notify_price_changes")
  
  lastUpdated   DateTime @default(now()) @map("last_updated")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([cityId])
  @@map("user_location_profiles")
}

