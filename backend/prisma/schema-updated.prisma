// Simplified Agro Trade Schema - MVP User Onboarding
// Version: 2.0 (With Product Catalog)
// Focus: User authentication, product catalog, and trading listings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  FARMER
  BUYER
  TRANSPORTER
  ADMIN
}

enum TruckType {
  FLATBED
  TANKER
  REEFER
  OTHER
}

enum ProductCategory {
  WHEAT
  CORN
  SUNFLOWER
  BARLEY
  OATS
  RAPESEED
  PEAS
  SOYBEAN_MEAL
  WHEAT_BRAN
  ALFALFA
  OTHER
}

enum ProductUnit {
  TON
  KG
}

enum ListingType {
  SELL
  BUY
}

enum ListingStatus {
  DRAFT
  ACTIVE
  RESERVED
  SOLD
  EXPIRED
  CANCELLED
}

enum DocumentType {
  ID_CARD
  BUSINESS_LICENSE
  VAT_CERT
  INSURANCE
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== CORE TABLES ====================

// 1. Users - Core authentication and identity
model User {
  id        String   @id @default(cuid())
  googleId  String?  @unique @map("google_id")
  email     String   @unique
  name      String?
  phone     String?
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  farmerProfile      FarmerProfile?
  buyerProfile       BuyerProfile?
  transporterProfile TransporterProfile?
  companyInfo        CompanyInfo?
  trucks             Truck[]
  listings           ProductListing[]
  documents          KycDocument[]
  fleetVehicles      FleetVehicle[]
  transporterBases   TransporterBase[] @relation("TransporterBases")

  @@map("users")
}

// 2. Role-based Profiles (unchanged)
model FarmerProfile {
  userId         String  @id @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  farmName       String? @map("farm_name")
  locationAddress String? @map("location_address")
  locationLat    Float?  @map("location_lat")
  locationLng    Float?  @map("location_lng")
  businessId     String? @map("business_id")
  iban           String?
  certifications Json?
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("farmer_profiles")
}

model BuyerProfile {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String? @map("company_name")
  vatId           String? @map("vat_id")
  billingAddress  Json?   @map("billing_address")
  paymentMethod   Json?   @map("payment_method")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("buyer_profiles")
}

model TransporterProfile {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String? @map("company_name")
  licenseNumber   String? @map("license_number")
  baseLocationAddress String? @map("base_location_address")
  baseLocationLat Float?  @map("base_location_lat")
  baseLocationLng Float?  @map("base_location_lng")
  insuranceDocUrl String? @map("insurance_doc_url")
  iban            String?
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("transporter_profiles")
}

// Company Information for enhanced registration flow
model CompanyInfo {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String  @map("company_name")
  vatNumber       String? @map("vat_number")
  businessLicense String? @map("business_license")
  companyAddress  Json?   @map("company_address")
  website         String?
  establishedYear Int?    @map("established_year")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("company_info")
}

// Multiple base locations for transporters
model TransporterBase {
  id            String  @id @default(cuid())
  transporterId String  @map("transporter_id")
  user          User    @relation("TransporterBases", fields: [transporterId], references: [id], onDelete: Cascade)
  
  name          String
  address       String
  latitude      Float
  longitude     Float
  isPrimary     Boolean @default(false) @map("is_primary")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([transporterId])
  @@map("transporter_bases")
}

// Enhanced fleet vehicle information for transporters
model FleetVehicle {
  id            String    @id @default(cuid())
  transporterId String    @map("transporter_id")
  transporter   User      @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  
  plateNumber   String    @map("plate_number")
  vehicleType   TruckType @map("vehicle_type")
  capacityKg    Int       @map("capacity_kg")
  year          Int?
  make          String?
  model         String?
  fuelType      String?   @map("fuel_type")
  active        Boolean   @default(true)
  
  registrationDoc String? @map("registration_doc")
  insuranceDoc    String? @map("insurance_doc")
  licenseDoc      String? @map("license_doc")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([transporterId])
  @@map("fleet_vehicles")
}

// 3. Assets
model Truck {
  id            String    @id @default(cuid())
  transporterId String    @map("transporter_id")
  transporter   User      @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  
  plateNumber   String    @map("plate_number")
  capacityKg    Int       @map("capacity_kg")
  type          TruckType
  active        Boolean   @default(true)
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([transporterId])
  @@map("trucks")
}

// ==================== NEW PRODUCT STRUCTURE ====================

// Product Catalog - Master list of all tradeable products
model ProductCatalog {
  id              String          @id @default(cuid())
  category        ProductCategory @unique
  name            String
  displayName     String          @map("display_name")
  description     String?         @db.Text
  image           String?         // Cloudinary URL
  
  // Product details
  nutritionalInfo String?         @map("nutritional_info") @db.Text
  useCases        Json?           @map("use_cases") // Array of strings
  harvestSeason   String?         @map("harvest_season")
  storageRecommendations String?  @map("storage_recommendations") @db.Text
  
  // Pricing guidance
  priceRangeMin   Decimal?        @map("price_range_min") @db.Decimal(10, 2)
  priceRangeMax   Decimal?        @map("price_range_max") @db.Decimal(10, 2)
  defaultUnit     ProductUnit     @default(TON) @map("default_unit")
  
  // Quality specifications
  qualityGrades   Json?           @map("quality_grades") // Array of strings
  certifications  Json?           // Common certifications
  specifications  Json?           // Technical specs
  
  // Meta
  isActive        Boolean         @default(true) @map("is_active")
  sortOrder       Int             @default(0) @map("sort_order")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  // Relations
  listings        ProductListing[]
  
  @@index([isActive])
  @@index([sortOrder])
  @@map("product_catalog")
}

// Product Listing - Actual buy/sell orders from users
model ProductListing {
  id              String          @id @default(cuid())
  
  // Link to catalog and user
  productId       String          @map("product_id")
  product         ProductCatalog  @relation(fields: [productId], references: [id])
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Listing details
  listingType     ListingType     @map("listing_type")
  title           String?         // Optional custom title
  description     String?         @db.Text // User's description
  
  // Quantity and pricing
  quantity        Decimal         @db.Decimal(10, 2)
  unit            ProductUnit
  pricePerUnit    Decimal         @map("price_per_unit") @db.Decimal(10, 2)
  totalValue      Decimal         @map("total_value") @db.Decimal(12, 2)
  negotiable      Boolean         @default(true)
  
  // Quality and specifications
  qualityGrade    String?         @map("quality_grade")
  certifications  Json?           // User's product certifications
  specifications  Json?           // Specific specs for this listing
  
  // Location
  locationAddress String?         @map("location_address")
  locationLat     Float?          @map("location_lat")
  locationLng     Float?          @map("location_lng")
  
  // Availability
  availableFrom   DateTime?       @map("available_from")
  availableTo     DateTime?       @map("available_to")
  harvestDate     DateTime?       @map("harvest_date") // For farmers
  deliveryBy      DateTime?       @map("delivery_by") // For buyers
  
  // Status
  status          ListingStatus   @default(DRAFT)
  viewCount       Int             @default(0) @map("view_count")
  
  // Additional media
  images          Json?           // Array of additional image URLs
  documents       Json?           // Related document URLs
  
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  expiresAt       DateTime?       @map("expires_at")
  
  @@index([userId])
  @@index([productId])
  @@index([listingType])
  @@index([status])
  @@index([createdAt])
  @@map("product_listings")
}

// 4. Compliance (unchanged)
model KycDocument {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  docType     DocumentType       @map("doc_type")
  docUrl      String             @map("doc_url")
  status      VerificationStatus @default(PENDING)
  submittedAt DateTime           @default(now()) @map("submitted_at")
  reviewedAt  DateTime?          @map("reviewed_at")
  reviewNotes String?            @map("review_notes")

  @@index([userId])
  @@index([status])
  @@map("kyc_documents")
}