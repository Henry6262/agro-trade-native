// ==================== TRADE OPERATIONS ====================
// This is the master entity that tracks the entire deal-making process

model TradeOperation {
  id              String              @id @default(cuid())
  operationNumber String              @unique @map("operation_number") // TRADE-2024-001
  
  // Admin who created/manages the operation
  adminId         String              @map("admin_id")
  admin           User                @relation(fields: [adminId], references: [id])
  
  // The buyer for this trade
  buyerId         String              @map("buyer_id")
  buyer           User                @relation("TradeBuyer", fields: [buyerId], references: [id])
  
  // Multiple sellers can be involved
  sellers         TradeSeller[]
  
  // Multiple transporters can be involved
  transporters    TradeTransporter[]
  
  // Current phase of the operation
  phase           TradePhase          @default(INITIATION)
  status          TradeStatus         @default(ACTIVE)
  
  // Total deal value
  totalValue      Decimal?            @map("total_value") @db.Decimal(10, 2)
  currency        String              @default("EUR")
  
  // Important dates
  initiatedAt     DateTime            @default(now()) @map("initiated_at")
  targetDelivery  DateTime?           @map("target_delivery")
  completedAt     DateTime?           @map("completed_at")
  
  // Related entities
  buyListing      BuyListing?         @relation(fields: [buyListingId], references: [id])
  buyListingId    String?             @map("buy_listing_id")
  
  negotiations    OfferNegotiation[]
  inspections     InspectionRequest[]
  transportBids   TransportBid[]
  
  // Audit trail
  stateHistory    TradeStateHistory[]
  notes           TradeNote[]
  
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  
  @@index([adminId])
  @@index([buyerId])
  @@index([phase])
  @@index([status])
  @@map("trade_operations")
}

model TradeSeller {
  id                String          @id @default(cuid())
  
  tradeOperationId  String          @map("trade_operation_id")
  tradeOperation    TradeOperation  @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  
  sellerId          String          @map("seller_id")
  seller            User            @relation(fields: [sellerId], references: [id])
  
  saleListingId     String?         @map("sale_listing_id")
  saleListing       SaleListing?    @relation(fields: [saleListingId], references: [id])
  
  // Seller-specific details for this trade
  quantity          Decimal         @db.Decimal(10, 2)
  unit              ProductUnit     @default(TON)
  agreedPrice       Decimal?        @map("agreed_price") @db.Decimal(10, 2)
  
  // Verification status
  isVerified        Boolean         @default(false) @map("is_verified")
  verificationId    String?         @map("verification_id")
  
  status            SellerStatus    @default(INVITED)
  
  joinedAt          DateTime        @default(now()) @map("joined_at")
  confirmedAt       DateTime?       @map("confirmed_at")
  
  @@unique([tradeOperationId, sellerId])
  @@index([tradeOperationId])
  @@index([sellerId])
  @@map("trade_sellers")
}

model TradeTransporter {
  id                String          @id @default(cuid())
  
  tradeOperationId  String          @map("trade_operation_id")
  tradeOperation    TradeOperation  @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  
  transporterId     String          @map("transporter_id")
  transporter       User            @relation(fields: [transporterId], references: [id])
  
  // Transport details
  pickupSellerId    String?         @map("pickup_seller_id")
  route             Json?           // GeoJSON or route details
  estimatedDistance Float?          @map("estimated_distance")
  agreedPrice       Decimal?        @map("agreed_price") @db.Decimal(10, 2)
  
  status            TransporterStatus @default(INVITED)
  
  assignedAt        DateTime        @default(now()) @map("assigned_at")
  confirmedAt       DateTime?       @map("confirmed_at")
  
  @@unique([tradeOperationId, transporterId])
  @@index([tradeOperationId])
  @@index([transporterId])
  @@map("trade_transporters")
}

// ==================== OFFER NEGOTIATIONS ====================

model OfferNegotiation {
  id                String          @id @default(cuid())
  
  tradeOperationId  String          @map("trade_operation_id")
  tradeOperation    TradeOperation  @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  
  // Parties involved
  buyerId           String          @map("buyer_id")
  buyer             User            @relation("NegotiationBuyer", fields: [buyerId], references: [id])
  
  sellerId          String          @map("seller_id")
  seller            User            @relation("NegotiationSeller", fields: [sellerId], references: [id])
  
  // Negotiation details
  status            NegotiationStatus @default(ACTIVE)
  
  // Price history
  initialOffer      Decimal         @map("initial_offer") @db.Decimal(10, 2)
  currentOffer      Decimal         @map("current_offer") @db.Decimal(10, 2)
  finalPrice        Decimal?        @map("final_price") @db.Decimal(10, 2)
  
  // Offer rounds
  offerRounds       OfferRound[]
  
  startedAt         DateTime        @default(now()) @map("started_at")
  concludedAt       DateTime?       @map("concluded_at")
  
  @@index([tradeOperationId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("offer_negotiations")
}

model OfferRound {
  id              String              @id @default(cuid())
  
  negotiationId   String              @map("negotiation_id")
  negotiation     OfferNegotiation    @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  
  roundNumber     Int                 @map("round_number")
  offeredBy       OfferParty          @map("offered_by") // BUYER, SELLER, PLATFORM
  
  price           Decimal             @db.Decimal(10, 2)
  quantity        Decimal             @db.Decimal(10, 2)
  terms           String?             @db.Text
  
  response        OfferResponse?      // ACCEPTED, REJECTED, COUNTERED
  responseNote    String?             @map("response_note")
  
  createdAt       DateTime            @default(now()) @map("created_at")
  respondedAt     DateTime?           @map("responded_at")
  
  @@unique([negotiationId, roundNumber])
  @@index([negotiationId])
  @@map("offer_rounds")
}

// ==================== INSPECTIONS ====================

model InspectionRequest {
  id                String          @id @default(cuid())
  
  tradeOperationId  String?         @map("trade_operation_id")
  tradeOperation    TradeOperation? @relation(fields: [tradeOperationId], references: [id])
  
  saleListingId     String          @map("sale_listing_id")
  saleListing       SaleListing     @relation(fields: [saleListingId], references: [id])
  
  inspectorId       String?         @map("inspector_id")
  inspector         User?           @relation(fields: [inspectorId], references: [id])
  
  // Priority and scheduling
  priority          InspectionPriority @default(MEDIUM)
  requestedDate     DateTime?       @map("requested_date")
  scheduledDate     DateTime?       @map("scheduled_date")
  completedDate     DateTime?       @map("completed_date")
  
  // Location
  latitude          Float
  longitude         Float
  address           String?
  
  // Inspection details
  status            InspectionStatus @default(PENDING)
  
  // Results
  verificationResult Json?          @map("verification_result") // Detailed inspection data
  qualityScore      Int?           @map("quality_score") // 0-100
  notes             String?        @db.Text
  photos            String[]       // URLs to inspection photos
  
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  
  @@index([tradeOperationId])
  @@index([saleListingId])
  @@index([inspectorId])
  @@index([status])
  @@index([priority])
  @@map("inspection_requests")
}

// ==================== TRANSPORT BIDDING ====================

model TransportBid {
  id                String          @id @default(cuid())
  
  tradeOperationId  String          @map("trade_operation_id")
  tradeOperation    TradeOperation  @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  
  transporterId     String          @map("transporter_id")
  transporter       User            @relation(fields: [transporterId], references: [id])
  
  // Bid details
  bidAmount         Decimal         @map("bid_amount") @db.Decimal(10, 2)
  estimatedDuration Int             @map("estimated_duration") // in hours
  vehicleType       TruckType       @map("vehicle_type")
  vehicleCapacity   Float           @map("vehicle_capacity")
  
  // Special conditions
  specialEquipment  String[]        @map("special_equipment")
  insuranceCoverage Decimal?        @map("insurance_coverage") @db.Decimal(10, 2)
  
  status            BidStatus       @default(PENDING)
  
  submittedAt       DateTime        @default(now()) @map("submitted_at")
  expiresAt         DateTime        @map("expires_at")
  
  @@index([tradeOperationId])
  @@index([transporterId])
  @@index([status])
  @@map("transport_bids")
}

// ==================== AUDIT & HISTORY ====================

model TradeStateHistory {
  id                String          @id @default(cuid())
  
  tradeOperationId  String          @map("trade_operation_id")
  tradeOperation    TradeOperation  @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  
  fromPhase         TradePhase?     @map("from_phase")
  toPhase           TradePhase      @map("to_phase")
  
  changedBy         String          @map("changed_by")
  user              User            @relation(fields: [changedBy], references: [id])
  
  reason            String?
  metadata          Json?           // Additional context
  
  changedAt         DateTime        @default(now()) @map("changed_at")
  
  @@index([tradeOperationId])
  @@index([changedBy])
  @@map("trade_state_history")
}

model TradeNote {
  id                String          @id @default(cuid())
  
  tradeOperationId  String          @map("trade_operation_id")
  tradeOperation    TradeOperation  @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  
  authorId          String          @map("author_id")
  author            User            @relation(fields: [authorId], references: [id])
  
  content           String          @db.Text
  isInternal        Boolean         @default(true) @map("is_internal") // Admin-only notes
  
  createdAt         DateTime        @default(now()) @map("created_at")
  
  @@index([tradeOperationId])
  @@index([authorId])
  @@map("trade_notes")
}

// ==================== NEW ENUMS ====================

enum TradePhase {
  INITIATION          // Trade operation created
  SELLER_MATCHING     // Finding and matching sellers
  SELLER_NEGOTIATION  // Negotiating with sellers
  INSPECTION_PENDING  // Waiting for product verification
  TRANSPORT_MATCHING  // Finding transporters
  TRANSPORT_BIDDING   // Transport bidding phase
  IN_TRANSIT          // Goods being transported
  DELIVERED           // Goods delivered
  COMPLETED           // Trade completed
  CANCELLED           // Trade cancelled
}

enum TradeStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  DISPUTED
}

enum SellerStatus {
  INVITED
  NEGOTIATING
  ACCEPTED
  REJECTED
  CONFIRMED
  WITHDRAWN
}

enum TransporterStatus {
  INVITED
  BIDDING
  SELECTED
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum NegotiationStatus {
  ACTIVE
  AGREED
  FAILED
  EXPIRED
}

enum OfferParty {
  BUYER
  SELLER
  PLATFORM
}

enum OfferResponse {
  ACCEPTED
  REJECTED
  COUNTERED
}

enum InspectionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InspectionStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

