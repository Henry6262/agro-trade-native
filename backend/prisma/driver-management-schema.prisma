// ==================== NEW ENUMS ====================

enum CompanyType {
  INTERNAL    // Agro-Trade's own fleet
  EXTERNAL    // Partner transport companies
}

enum DriverType {
  INTERNAL    // Agro-Trade employee drivers
  EXTERNAL    // Drivers from partner companies
}

enum AdminLevel {
  OWNER       // Company owner
  MANAGER     // Fleet manager
  DISPATCHER  // Can assign drivers
  VIEWER      // Read-only access
}

enum OwnerType {
  AGROTRADE   // Owned by Agro-Trade
  COMPANY     // Owned by transport company
  INDIVIDUAL  // Owner-operator
}

enum DriverStatus {
  OFFLINE
  AVAILABLE
  ON_BREAK
  ASSIGNED
  EN_ROUTE
  AT_PICKUP
  IN_TRANSIT
  AT_DELIVERY
  COMPLETED
}

enum CompanyDocumentType {
  REGISTRATION_CERTIFICATE
  OPERATING_LICENSE
  INSURANCE_CERTIFICATE
  TAX_CERTIFICATE
  SAFETY_CERTIFICATE
  OTHER
}

enum DriverDocumentType {
  DRIVING_LICENSE
  MEDICAL_CERTIFICATE
  TRAINING_CERTIFICATE
  IDENTITY_CARD
  OTHER
}