// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS & AUTH ====================

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String?
  name                String?
  phoneNumber         String?   @unique @map("phone_number")
  pushToken           String?   @map("push_token")
  role                UserRole  @default(BUYER)
  isActive            Boolean   @default(true) @map("is_active")
  isEmailVerified     Boolean   @default(false) @map("is_email_verified")
  isPhoneVerified     Boolean   @default(false) @map("is_phone_verified")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  lastLogin           DateTime? @map("last_login")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  company   Company?
  addresses Address[]
  trucks    Truck[] // For transporters

  // New driver management relations
  companyAdmin  CompanyAdmin? // If user is a company admin
  driverProfile Driver? // If user is an internal driver

  // Marketplace activities
  saleListings SaleListing[] @relation("SellerListings")
  buyListings  BuyListing[]  @relation("BuyerListings")

  // Trade operation relations
  tradeOperationsManaged    TradeOperation[]           @relation("TradeAdmin")
  tradeSellers              TradeSeller[]
  tradeTransporters         TradeTransporter[]
  inspectionAssignments     InspectionRequest[]        @relation("InspectorAssignments")
  transportBids             TransportBid[]
  transportJobs             TransportJob[]
  tradeStateChanges         TradeStateHistory[]
  tradeNotes                TradeNote[]
  transportCostCalculations TransportCostCalculation[]
  profitEstimations         ProfitEstimation[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String   @db.VarChar(20)
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([phone, used, expiresAt])
  @@map("phone_otps")
}

model Company {
  id String @id @default(cuid())

  // Link to user
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Company details
  legalName          String  @map("legal_name")
  registrationNumber String? @map("registration_number")
  vatNumber          String? @map("vat_number")
  phoneNumber        String? @map("phone_number")
  email              String?
  website            String?

  // Relations
  addresses Address[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

// ==================== ADDRESSES ====================

model Address {
  id String @id @default(cuid())

  // Relations (an address can belong to different entities)
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Address details
  addressType AddressType @map("address_type")
  label       String? // "Main Farm", "Warehouse #2", etc.

  street     String?
  cityId     String? @map("city_id")
  city       City?   @relation(fields: [cityId], references: [id])
  postalCode String? @map("postal_code")
  country    String?

  latitude  Float?
  longitude Float?

  isDefault Boolean @default(false) @map("is_default")

  // Used by
  saleListings SaleListing[] @relation("ListingAddress")
  buyListings  BuyListing[]  @relation("DeliveryAddress")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([companyId])
  @@map("addresses")
}

// ==================== LOCATION HIERARCHY ====================

model Region {
  id       String  @id @default(cuid())
  name     String // Northwestern, North Central, etc.
  country  String // Bulgaria, Greece
  isActive Boolean @default(true) @map("is_active")

  // Cities in this region
  cities City[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, country])
  @@index([country])
  @@map("regions")
}

model City {
  id   String @id @default(cuid())
  name String // Sofia, Plovdiv, Varna, etc.

  regionId String @map("region_id")
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  // Relations
  addresses      Address[]
  regionalPrices RegionalPrice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, regionId])
  @@index([regionId])
  @@map("cities")
}

// ==================== PRODUCT DEFINITIONS ====================

model Product {
  id          String          @id @default(cuid())
  category    ProductCategory @unique
  name        String          @unique
  displayName String          @map("display_name")
  description String?         @db.Text
  image       String? // Cloudinary URL

  // Product characteristics
  harvestSeason          String? @map("harvest_season")
  storageRecommendations String? @map("storage_recommendations") @db.Text

  // Price guidance
  priceRangeMin Decimal?    @map("price_range_min") @db.Decimal(10, 2)
  priceRangeMax Decimal?    @map("price_range_max") @db.Decimal(10, 2)
  defaultUnit   ProductUnit @default(TON) @map("default_unit")

  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int?    @map("sort_order")

  // Relations
  specTemplates  ProductSpecTemplate[]
  saleListings   SaleListing[]
  buyListings    BuyListing[]
  regionalPrices RegionalPrice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("products")
}

// ==================== FLEXIBLE SPECIFICATION SYSTEM ====================

model SpecificationType {
  id       String   @id @default(cuid())
  code     String   @unique // moisture, protein, oil_content, test_weight, etc.
  name     String // "Moisture Content", "Protein Content", etc.
  unit     String? // "%", "kg/hl", "ppm", etc.
  dataType DataType // NUMBER, TEXT, BOOLEAN, ENUM

  // For ENUM types, store options
  enumOptions Json? // ["Grade A", "Grade B", "Feed Grade"]

  // Validation rules
  minValue Float?
  maxValue Float?

  // Used in specifications
  productSpecTemplates ProductSpecTemplate[]
  listingSpecs         ListingSpec[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("specification_types")
}

model ProductSpecTemplate {
  id String @id @default(cuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  specTypeId        String            @map("spec_type_id")
  specificationType SpecificationType @relation(fields: [specTypeId], references: [id])

  // How important is this spec for this product?
  importance Importance // CRITICAL, IMPORTANT, OPTIONAL

  displayOrder Int @default(0) @map("display_order") // Order in UI forms

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([productId, specTypeId])
  @@index([productId])
  @@map("product_spec_templates")
}

// ==================== MARKETPLACE LISTINGS ====================

model SaleListing {
  id String @id @default(cuid())

  // What product is being sold
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  // Who is selling
  sellerId String @map("seller_id")
  seller   User   @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)

  // Location
  addressId String?  @map("address_id")
  address   Address? @relation("ListingAddress", fields: [addressId], references: [id])

  // Listing details
  quantity Decimal     @db.Decimal(10, 2)
  unit     ProductUnit @default(TON)

  // Seller's asking price (optional - platform can suggest)
  askingPrice Decimal? @map("asking_price") @db.Decimal(10, 2)

  // Product specifics
  harvestDate DateTime? @map("harvest_date")

  // Quality specifications (flexible - seller provides what they know)
  specifications ListingSpec[]

  // Platform-calculated quality assessment
  qualityScore Int?    @map("quality_score") // 0-100 based on provided specs
  qualityGrade String? @map("quality_grade") // "Premium", "Standard", "Feed"

  // Status and visibility
  status    ListingStatus @default(ACTIVE)
  viewCount Int           @default(0) @map("view_count")

  // Offers made for this listing
  offers Offer[]

  // Trade operation relations
  tradeSellers       TradeSeller[]
  inspectionRequests InspectionRequest[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([productId])
  @@index([addressId])
  @@index([status])
  @@map("sale_listings")
}

model BuyListing {
  id String @id @default(cuid())

  // What product is needed
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  // Who is buying
  buyerId String @map("buyer_id")
  buyer   User   @relation("BuyerListings", fields: [buyerId], references: [id], onDelete: Cascade)

  // Delivery location
  deliveryAddressId String?  @map("delivery_address_id")
  deliveryAddress   Address? @relation("DeliveryAddress", fields: [deliveryAddressId], references: [id])

  // Purchase details
  quantity Decimal     @db.Decimal(10, 2)
  unit     ProductUnit @default(TON)

  // Budget
  maxPricePerUnit Decimal? @map("max_price_per_unit") @db.Decimal(10, 2)

  // Timeline
  neededBy DateTime? @map("needed_by")

  // Required specifications
  specifications ListingSpec[]

  // Status
  status RequestStatus @default(ACTIVE)

  // Offers received for this request
  offers Offer[]

  // Trade operation relation
  tradeOperation TradeOperation? // One-to-one: one buy listing can have one trade operation

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([buyerId])
  @@index([productId])
  @@index([deliveryAddressId])
  @@index([status])
  @@map("buy_listings")
}

// ==================== UNIFIED SPECIFICATION VALUES ====================

model ListingSpec {
  id String @id @default(cuid())

  // Can belong to either sale or buy listing
  saleListingId String?      @map("sale_listing_id")
  saleListing   SaleListing? @relation(fields: [saleListingId], references: [id], onDelete: Cascade)

  buyListingId String?     @map("buy_listing_id")
  buyListing   BuyListing? @relation(fields: [buyListingId], references: [id], onDelete: Cascade)

  specTypeId        String            @map("spec_type_id")
  specificationType SpecificationType @relation(fields: [specTypeId], references: [id])

  // For sale listings: actual values
  // For buy listings: exact requirements or midpoint of range
  valueNumber Float?   @map("value_number")
  valueText   String?  @map("value_text")
  valueBool   Boolean? @map("value_bool")

  // For buy listings: acceptable ranges
  minValue Float? @map("min_value")
  maxValue Float? @map("max_value")

  // Platform assessment (for sale listings)
  qualityImpact QualityImpact? @map("quality_impact") // POSITIVE, NEUTRAL, NEGATIVE

  // How strict is this requirement (for buy listings)
  strictness Strictness? // MANDATORY, PREFERRED, OPTIONAL

  // Price impact for variations (for buy listings)
  priceAdjustmentPerUnit Decimal? @map("price_adjustment_per_unit") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([saleListingId, specTypeId])
  @@unique([buyListingId, specTypeId])
  @@index([saleListingId])
  @@index([buyListingId])
  @@map("listing_specs")
}

// ==================== MATCHING & OFFERS ====================

model Offer {
  id String @id @default(cuid())

  // Linking supply and demand
  saleListingId String?      @map("sale_listing_id")
  saleListing   SaleListing? @relation(fields: [saleListingId], references: [id], onDelete: Cascade)

  buyListingId String?     @map("buy_listing_id")
  buyListing   BuyListing? @relation(fields: [buyListingId], references: [id], onDelete: Cascade)

  // Offer details
  offeredPrice Decimal     @map("offered_price") @db.Decimal(10, 2)
  quantity     Decimal     @db.Decimal(10, 2)
  unit         ProductUnit @default(TON)

  // Quality match assessment
  matchScore   Int   @map("match_score") // 0-100 based on spec alignment
  matchDetails Json? @map("match_details") // Detailed breakdown of spec matches

  // Price calculation breakdown
  basePrice         Decimal  @map("base_price") @db.Decimal(10, 2)
  qualityAdjustment Decimal? @map("quality_adjustment") @db.Decimal(10, 2)
  quantityDiscount  Decimal? @map("quantity_discount") @db.Decimal(10, 2)
  transportCost     Decimal? @map("transport_cost") @db.Decimal(10, 2)
  finalPrice        Decimal  @map("final_price") @db.Decimal(10, 2)

  // Terms
  validUntil    DateTime @map("valid_until")
  deliveryTerms String?  @map("delivery_terms")
  paymentTerms  String?  @map("payment_terms")

  // Status tracking
  status          OfferStatus @default(PENDING)
  rejectionReason String?     @map("rejection_reason")

  // Who created the offer
  createdBy OfferCreator @map("created_by") // PLATFORM, SELLER, BUYER

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([saleListingId])
  @@index([buyListingId])
  @@index([status])
  @@map("offers")
}

// ==================== REGIONAL PRICING ====================

model RegionalPrice {
  id String @id @default(cuid())

  cityId String @map("city_id")
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  pricePerUnit Decimal     @map("price_per_unit") @db.Decimal(10, 2)
  currency     String      @default("EUR")
  unit         ProductUnit @default(TON)

  // Track price changes
  lastUpdated DateTime @default(now()) @map("last_updated")

  @@unique([cityId, productId])
  @@index([cityId])
  @@index([productId])
  @@map("regional_prices")
}

// ==================== TRANSPORT ====================

model Truck {
  id String @id @default(cuid())

  // Owner (must be a transporter)
  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Ownership type
  ownerType OwnerType @default(INDIVIDUAL) @map("owner_type")

  // For company-owned trucks
  transportCompanyId String?           @map("transport_company_id")
  transportCompany   TransportCompany? @relation(fields: [transportCompanyId], references: [id])

  // Current driver
  currentDriverId String? @unique @map("current_driver_id")
  currentDriver   Driver? @relation("CurrentDriver", fields: [currentDriverId], references: [id])

  plateNumber String      @unique @map("plate_number")
  capacity    Float // in tons
  unit        ProductUnit @default(TON)
  type        TruckType

  // Current status
  currentLocation String? @map("current_location")
  latitude        Float?
  longitude       Float?
  isAvailable     Boolean @default(true) @map("is_available")

  // Trade operation relations
  tradeTransporters TradeTransporter[]
  transportBids     TransportBid[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("trucks")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  FARMER
  BUYER
  TRANSPORTER
  COMPANY_ADMIN // Transport company administrators
  INSPECTOR
}

enum AddressType {
  BILLING
  SHIPPING
  FARM
  WAREHOUSE
  OFFICE
  PICKUP
  DELIVERY
  OTHER
}

enum ProductCategory {
  SOFT_WHEAT // Pastry/cake flour grade
  DURUM_WHEAT // Pasta production grade
  CORN_MAIZE // Feed and processing
  BARLEY // Malting and feed
  OATS // Milling and feed
  SUNFLOWER // High oleic oil production
  RAPESEED // Oil and biodiesel
  PEAS // Food and feed grade
  SOYBEAN_MEAL // High protein feed
  WHEAT_BRAN // Animal feed
  ALFALFA // Livestock feed
  OTHER // Various cereals & oilseeds
}

enum ProductUnit {
  TON
  KG
  LITER
  PIECE
}

enum DataType {
  NUMBER
  TEXT
  BOOLEAN
  ENUM
}

enum Importance {
  CRITICAL // Must have for this product type
  IMPORTANT // Should have for pricing
  OPTIONAL // Nice to have
}

enum QualityImpact {
  POSITIVE // Better than standard
  NEUTRAL // Within standard range
  NEGATIVE // Below standard
}

enum Strictness {
  MANDATORY // Must meet requirement
  PREFERRED // Should meet, but flexible
  OPTIONAL // Nice to have
}

enum ListingStatus {
  ACTIVE
  SOLD
  PENDING
  EXPIRED
  CANCELLED
}

enum RequestStatus {
  ACTIVE
  FULFILLED
  PARTIALLY_FULFILLED
  EXPIRED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
  NEGOTIATING
}

enum OfferCreator {
  PLATFORM // Auto-generated by matching algorithm
  SELLER // Direct offer from seller
  BUYER // Counter-offer from buyer
}

enum TruckType {
  FLATBED
  REFRIGERATED
  TANKER
  CONTAINER
  CURTAIN_SIDE
  BOX_TRUCK
  OTHER
}

// ==================== TRADE OPERATIONS MODELS ====================

model TradeOperation {
  id              String @id @default(cuid())
  operationNumber String @unique @map("operation_number")

  // Admin managing this operation
  adminId String @map("admin_id")
  admin   User   @relation("TradeAdmin", fields: [adminId], references: [id])

  // Link to the BuyListing being fulfilled (REQUIRED - this is the source of requirements)
  buyListingId String     @unique @map("buy_listing_id") // UNIQUE: one listing = one operation
  buyListing   BuyListing @relation(fields: [buyListingId], references: [id])

  // Trade details
  phase    TradePhase  @default(INITIATION)
  status   TradeStatus @default(ACTIVE)
  currency String      @default("EUR")

  // Buying side (what we pay to sellers)
  totalPurchaseCost Decimal? @map("total_purchase_cost") @db.Decimal(10, 2)
  avgPurchasePrice  Decimal? @map("avg_purchase_price") @db.Decimal(10, 2)

  // Selling side (what buyer pays us)
  sellingPrice Decimal? @map("selling_price") @db.Decimal(10, 2)
  totalRevenue Decimal? @map("total_revenue") @db.Decimal(10, 2)

  // Transport costs
  estimatedTransportCost Decimal? @map("estimated_transport_cost") @db.Decimal(10, 2)
  actualTransportCost    Decimal? @map("actual_transport_cost") @db.Decimal(10, 2)
  totalDistanceKm        Float?   @map("total_distance_km")

  // Profit metrics
  estimatedProfit Decimal? @map("estimated_profit") @db.Decimal(10, 2)
  actualProfit    Decimal? @map("actual_profit") @db.Decimal(10, 2)
  profitMargin    Float?   @map("profit_margin")

  // Dates
  initiatedAt DateTime  @default(now()) @map("initiated_at")
  completedAt DateTime? @map("completed_at")

  // Flexible metadata
  metadata Json?

  // Relations
  sellers                   TradeSeller[]
  transporters              TradeTransporter[]
  negotiations              OfferNegotiation[]
  inspections               InspectionRequest[]
  transportRequest          TransportRequest?
  transportBids             TransportBid[]
  transportJobs             TransportJob[]
  stateHistory              TradeStateHistory[]
  notes                     TradeNote[]
  transportCostCalculations TransportCostCalculation[]
  profitEstimations         ProfitEstimation[]
  tradeEvents               TradeEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([adminId])
  @@index([buyListingId])
  @@index([phase])
  @@index([status])
    // NI-21: Composite indexes for common query patterns
  @@index([adminId, status])
  @@index([status, phase])
  @@index([createdAt])
  @@map("trade_operations")
}

model TradeSeller {
  id String @id @default(cuid())

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  sellerId String @map("seller_id")
  seller   User   @relation(fields: [sellerId], references: [id])

  saleListingId String      @map("sale_listing_id") // REQUIRED - we always select from existing listings
  saleListing   SaleListing @relation(fields: [saleListingId], references: [id])

  // Quantities
  requestedQuantity Decimal     @map("requested_quantity") @db.Decimal(10, 2) // What buyer needs
  offeredQuantity   Decimal     @map("offered_quantity") @db.Decimal(10, 2) // What seller has
  agreedQuantity    Decimal?    @map("agreed_quantity") @db.Decimal(10, 2) // Final agreed
  unit              ProductUnit @default(TON)
  agreedPrice       Decimal?    @map("agreed_price") @db.Decimal(10, 2)

  // Verification (linked to SaleListing verification status)
  isVerified Boolean @default(false) @map("is_verified")

  // Match quality
  matchScore Int? @map("match_score") // 0-100 based on spec alignment

  status SellerStatus @default(INVITED)

  // Negotiation for this seller
  negotiation OfferNegotiation?

  joinedAt    DateTime  @default(now()) @map("joined_at")
  confirmedAt DateTime? @map("confirmed_at")

  @@unique([tradeOperationId, saleListingId]) // Can't add same listing twice
  @@index([tradeOperationId])
  @@index([sellerId])
  @@index([saleListingId])
  @@index([status])
  @@map("trade_sellers")
}

model TradeTransporter {
  id String @id @default(cuid())

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  transporterId String @map("transporter_id")
  transporter   User   @relation(fields: [transporterId], references: [id])

  // Route details
  pickupSellerId    String?  @map("pickup_seller_id")
  route             Json?
  estimatedDistance Float?   @map("estimated_distance")
  estimatedDuration Int?     @map("estimated_duration") // in minutes
  agreedPrice       Decimal? @map("agreed_price") @db.Decimal(10, 2)

  vehicleId String? @map("vehicle_id")
  vehicle   Truck?  @relation(fields: [vehicleId], references: [id])

  status TransporterStatus @default(INVITED)

  assignedAt  DateTime  @default(now()) @map("assigned_at")
  confirmedAt DateTime? @map("confirmed_at")
  deliveredAt DateTime? @map("delivered_at")

  @@unique([tradeOperationId, transporterId])
  @@index([tradeOperationId])
  @@index([transporterId])
  @@index([status])
  @@map("trade_transporters")
}

model OfferNegotiation {
  id String @id @default(cuid())

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  // Link to the specific TradeSeller being negotiated with
  tradeSellerId String      @unique @map("trade_seller_id")
  tradeSeller   TradeSeller @relation(fields: [tradeSellerId], references: [id])

  // Negotiation status
  status NegotiationStatus @default(PENDING)

  // Current offer from admin
  currentOffer Json @map("current_offer") // {price, quantity, terms}

  // Counter-offer from seller (if any)
  counterOffer Json? @map("counter_offer") // {price, quantity, terms, receivedAt}

  // History of all offers
  offerHistory Json[] @default([]) @map("offer_history")

  // Final agreed terms (when status = ACCEPTED)
  finalPrice    Decimal? @map("final_price") @db.Decimal(10, 2)
  finalQuantity Decimal? @map("final_quantity") @db.Decimal(10, 2)

  unit ProductUnit @default(TON)

  // Timing
  startedAt   DateTime  @default(now()) @map("started_at")
  respondedAt DateTime? @map("responded_at") // When seller responded
  concludedAt DateTime? @map("concluded_at") // When negotiation finished
  expiresAt   DateTime  @map("expires_at") // 48 hours from creation

  // Offer rounds for detailed tracking
  offerRounds OfferRound[]

  @@index([tradeOperationId])
  @@index([tradeSellerId])
  @@index([status])
  @@index([expiresAt])
  @@map("offer_negotiations")
}

model OfferRound {
  id String @id @default(cuid())

  negotiationId String           @map("negotiation_id")
  negotiation   OfferNegotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  roundNumber Int        @map("round_number")
  offeredBy   OfferParty @map("offered_by")

  price    Decimal @db.Decimal(10, 2)
  quantity Decimal @db.Decimal(10, 2)
  terms    String? @db.Text

  response     OfferResponse?
  responseNote String?        @map("response_note")

  createdAt   DateTime  @default(now()) @map("created_at")
  respondedAt DateTime? @map("responded_at")

  @@unique([negotiationId, roundNumber])
  @@index([negotiationId])
  @@map("offer_rounds")
}

model InspectionRequest {
  id String @id @default(cuid())

  tradeOperationId String?         @map("trade_operation_id")
  tradeOperation   TradeOperation? @relation(fields: [tradeOperationId], references: [id])

  saleListingId String      @map("sale_listing_id")
  saleListing   SaleListing @relation(fields: [saleListingId], references: [id])

  inspectorId String? @map("inspector_id")
  inspector   User?   @relation("InspectorAssignments", fields: [inspectorId], references: [id])

  // Priority and scheduling
  priority      InspectionPriority @default(MEDIUM)
  requestedDate DateTime?          @map("requested_date")
  scheduledDate DateTime?          @map("scheduled_date")
  completedDate DateTime?          @map("completed_date")

  // Location
  latitude  Float
  longitude Float
  address   String?

  // Results
  status             InspectionStatus @default(PENDING)
  qualityScore       Int?             @map("quality_score")
  verificationResult Json?            @map("verification_result")
  notes              String?          @db.Text
  photos             String[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tradeOperationId])
  @@index([saleListingId])
  @@index([inspectorId])
  @@index([status])
  @@index([priority])
  @@map("inspection_requests")
}

model TransportRequest {
  id            String @id @default(cuid())
  requestNumber String @unique @map("request_number")

  tradeOperationId String         @unique @map("trade_operation_id") // One request per trade
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  // Transport requirements
  totalWeight         Float      @map("total_weight") // Total tons to transport
  requiredVehicleType TruckType? @map("required_vehicle_type")
  specialRequirements String[]   @map("special_requirements")

  // Route information
  pickupPoints      Json   @map("pickup_points") // Array of {lat, lng, sellerId, quantity, address}
  deliveryPoint     Json   @map("delivery_point") // {lat, lng, addressId, address}
  estimatedDistance Float? @map("estimated_distance") // Total km

  // Timeline
  pickupWindowStart DateTime?    @map("pickup_window_start")
  pickupWindowEnd   DateTime?    @map("pickup_window_end")
  deliveryDeadline  DateTime?    @map("delivery_deadline")
  urgencyLevel      UrgencyLevel @default(STANDARD) @map("urgency_level")

  // Status and bidding
  status          TransportRequestStatus @default(OPEN)
  biddingDeadline DateTime               @map("bidding_deadline")
  maxBudget       Decimal?               @map("max_budget") @db.Decimal(10, 2)

  // Selected bid (when assigned)
  selectedBidId String?       @unique @map("selected_bid_id")
  selectedBid   TransportBid? @relation("SelectedBid", fields: [selectedBidId], references: [id])

  // Related bids
  bids TransportBid[] @relation("RequestBids")

  // Transport job (when assigned)
  transportJob TransportJob?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([urgencyLevel])
  @@index([biddingDeadline])
  @@map("transport_requests")
}

model TransportBid {
  id String @id @default(cuid())

  transportRequestId String           @map("transport_request_id")
  transportRequest   TransportRequest @relation("RequestBids", fields: [transportRequestId], references: [id], onDelete: Cascade)

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  transporterId String @map("transporter_id")
  transporter   User   @relation(fields: [transporterId], references: [id])

  // Link to transport company (for external bids)
  transportCompanyId String?           @map("transport_company_id")
  transportCompany   TransportCompany? @relation(fields: [transportCompanyId], references: [id])

  // Bid details
  bidAmount         Decimal   @map("bid_amount") @db.Decimal(10, 2)
  estimatedDuration Int       @map("estimated_duration") // in hours
  vehicleType       TruckType @map("vehicle_type")
  vehicleCapacity   Float     @map("vehicle_capacity")

  // Vehicle assignment
  assignedTruckId String? @map("assigned_truck_id")
  assignedTruck   Truck?  @relation(fields: [assignedTruckId], references: [id])

  specialEquipment  String[] @map("special_equipment")
  insuranceCoverage Decimal? @map("insurance_coverage") @db.Decimal(10, 2)
  proposedRoute     Json?    @map("proposed_route")
  pickupSchedule    Json?    @map("pickup_schedule") // Detailed schedule for multiple pickups

  status BidStatus @default(PENDING)

  // Bid lifecycle
  submittedAt DateTime  @default(now()) @map("submitted_at")
  expiresAt   DateTime  @map("expires_at")
  evaluatedAt DateTime? @map("evaluated_at")
  acceptedAt  DateTime? @map("accepted_at")

  // If this bid is selected
  selectedRequest TransportRequest? @relation("SelectedBid")

  // Transport job (when bid is accepted)
  transportJob TransportJob?

  @@index([transportRequestId])
  @@index([tradeOperationId])
  @@index([transporterId])
  @@index([status])
  @@map("transport_bids")
}

model TransportJob {
  id        String @id @default(cuid())
  jobNumber String @unique @map("job_number")

  transportRequestId String           @unique @map("transport_request_id")
  transportRequest   TransportRequest @relation(fields: [transportRequestId], references: [id])

  transportBidId String       @unique @map("transport_bid_id")
  transportBid   TransportBid @relation(fields: [transportBidId], references: [id])

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id])

  transporterId String @map("transporter_id")
  transporter   User   @relation(fields: [transporterId], references: [id])

  // Driver assignment
  assignedDriverId String? @map("assigned_driver_id")
  assignedDriver   Driver? @relation("DriverJobHistory", fields: [assignedDriverId], references: [id])

  // Current driver job (opposite relation)
  currentDriverJob Driver? @relation("CurrentDriverJob")

  // Company tracking (for external jobs)
  transportCompanyId String?           @map("transport_company_id")
  transportCompany   TransportCompany? @relation(fields: [transportCompanyId], references: [id])

  // Job status and timeline
  status TransportJobStatus @default(ASSIGNED)

  // Pickup tracking
  pickupsCompleted   Json    @default("[]") @map("pickups_completed") // Array of completed pickup records
  allPickupsComplete Boolean @default(false) @map("all_pickups_complete")

  // Delivery tracking  
  currentLocation  Json?     @map("current_location") // {lat, lng, timestamp, address}
  estimatedArrival DateTime? @map("estimated_arrival")
  actualDelivery   DateTime? @map("actual_delivery")

  // Documentation
  pickupPhotos    String[] @map("pickup_photos")
  deliveryPhotos  String[] @map("delivery_photos")
  proofOfDelivery String?  @map("proof_of_delivery") // Document URL

  // Performance metrics
  onTimePickup   Boolean? @map("on_time_pickup")
  onTimeDelivery Boolean? @map("on_time_delivery")
  customerRating Int?     @map("customer_rating") // 1-5 stars
  notes          String?  @db.Text

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([transporterId])
  @@index([tradeOperationId])
  @@map("transport_jobs")
}

model TradeStateHistory {
  id String @id @default(cuid())

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  fromPhase  TradePhase?  @map("from_phase")
  toPhase    TradePhase   @map("to_phase")
  fromStatus TradeStatus? @map("from_status")
  toStatus   TradeStatus? @map("to_status")

  changedBy String @map("changed_by")
  user      User   @relation(fields: [changedBy], references: [id])

  reason   String?
  metadata Json?

  changedAt DateTime @default(now()) @map("changed_at")

  @@index([tradeOperationId])
  @@index([changedBy])
  @@index([changedAt])
  @@map("trade_state_history")
}

model TradeNote {
  id String @id @default(cuid())

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id])

  content     String   @db.Text
  isInternal  Boolean  @default(true) @map("is_internal")
  attachments String[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tradeOperationId])
  @@index([authorId])
  @@map("trade_notes")
}

// ==================== TRADE EVENTS (Audit Log for EU Grant Traceability) ====================

enum TradeEventType {
  LISTING_CREATED
  BID_SUBMITTED
  BID_ACCEPTED
  INSPECTION_SCHEDULED
  INSPECTION_COMPLETED
  TRANSPORT_PICKUP
  TRANSPORT_DELIVERED
  PAYMENT_ESCROWED
  PAYMENT_RELEASED
  DISPUTE_RAISED
}

model TradeEvent {
  id               String         @id @default(cuid())
  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  eventType        TradeEventType @map("event_type")
  actorRole        String         @map("actor_role") // FARMER | BUYER | TRANSPORTER | INSPECTOR | ADMIN
  actorId          String?        @map("actor_id")
  commodityCode    String?        @map("commodity_code") // GS1/CN code e.g. "1001" for wheat
  quantityKg       Float?         @map("quantity_kg")
  pricePerKg       Float?         @map("price_per_kg")
  locationLat      Float?         @map("location_lat")
  locationLng      Float?         @map("location_lng")
  regionCode       String?        @map("region_code")
