  blockchainTxHash String?        @map("blockchain_tx_hash")
  metadata         Json?
  timestamp        DateTime       @default(now())

  @@index([tradeOperationId])
  @@index([eventType])
  @@index([regionCode])
  @@index([timestamp])
  @@map("trade_events")
}

// ==================== PROFIT CALCULATION MODELS ====================

model TransportCostCalculation {
  id String @id @default(cuid())

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  // Route details
  pickupPoints  Json  @map("pickup_points") // Array of {lat, lng, sellerId, quantity}
  deliveryPoint Json  @map("delivery_point") // {lat, lng, addressId}
  optimalRoute  Json? @map("optimal_route") // Calculated optimal sequence
  totalDistance Float @map("total_distance") // Total km

  // Cost breakdown
  baseRatePerKm    Decimal    @map("base_rate_per_km") @db.Decimal(10, 4) // €0.15 default
  vehicleType      TruckType? @map("vehicle_type")
  distanceCost     Decimal    @map("distance_cost") @db.Decimal(10, 2)
  loadingCosts     Decimal?   @map("loading_costs") @db.Decimal(10, 2)
  urgencySurcharge Decimal?   @map("urgency_surcharge") @db.Decimal(10, 2)
  totalCost        Decimal    @map("total_cost") @db.Decimal(10, 2)

  // Metadata
  calculatedBy String   @map("calculated_by")
  user         User     @relation(fields: [calculatedBy], references: [id])
  calculatedAt DateTime @default(now()) @map("calculated_at")

  @@index([tradeOperationId])
  @@map("transport_cost_calculations")
}

model ProfitEstimation {
  id String @id @default(cuid())

  tradeOperationId String         @map("trade_operation_id")
  tradeOperation   TradeOperation @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  // Snapshot of negotiation state
  proposedBuyerPrice   Decimal @map("proposed_buyer_price") @db.Decimal(10, 2)
  proposedSellerPrices Json    @map("proposed_seller_prices") // Array of {sellerId, price, quantity}

  // Calculated metrics
  estimatedRevenue       Decimal @map("estimated_revenue") @db.Decimal(10, 2)
  estimatedPurchaseCost  Decimal @map("estimated_purchase_cost") @db.Decimal(10, 2)
  estimatedTransportCost Decimal @map("estimated_transport_cost") @db.Decimal(10, 2)
  estimatedProfit        Decimal @map("estimated_profit") @db.Decimal(10, 2)
  profitMargin           Float   @map("profit_margin") // Percentage

  // Risk assessment
  priceVolatilityRisk Float? @map("price_volatility_risk") // 0-100
  qualityRisk         Float? @map("quality_risk") // 0-100
  transportRisk       Float? @map("transport_risk") // 0-100
  overallRisk         Float? @map("overall_risk") // 0-100

  // Metadata
  notes     String?  @db.Text
  createdBy String   @map("created_by")
  user      User     @relation(fields: [createdBy], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tradeOperationId])
  @@index([createdAt])
  @@map("profit_estimations")
}

model TransportCostSettings {
  id String @id @default(cuid())

  // Base rates
  baseRatePerKm Decimal @default(0.15) @map("base_rate_per_km") @db.Decimal(10, 4)

  // Vehicle type multipliers
  flatbedMultiplier      Float @default(1.0) @map("flatbed_multiplier")
  refrigeratedMultiplier Float @default(1.3) @map("refrigerated_multiplier")
  tankerMultiplier       Float @default(1.2) @map("tanker_multiplier")
  containerMultiplier    Float @default(1.1) @map("container_multiplier")

  // Distance-based pricing tiers
  tier1MaxKm Int     @default(50) @map("tier1_max_km")
  tier1Rate  Decimal @default(0.15) @map("tier1_rate") @db.Decimal(10, 4)
  tier2MaxKm Int     @default(200) @map("tier2_max_km")
  tier2Rate  Decimal @default(0.13) @map("tier2_rate") @db.Decimal(10, 4)
  tier3Rate  Decimal @default(0.11) @map("tier3_rate") @db.Decimal(10, 4) // 200km+

  // Additional costs
  loadingCostPerTon Decimal @default(0.50) @map("loading_cost_per_ton") @db.Decimal(10, 2)
  urgencySurcharge  Float   @default(0.3) @map("urgency_surcharge") // 30% for express

  // Validity period
  effectiveFrom DateTime  @default(now()) @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, effectiveFrom])
  @@map("transport_cost_settings")
}

// ==================== TRANSPORT COMPANY & DRIVER MANAGEMENT MODELS ====================

model TransportCompany {
  id String @id @default(cuid())

  // Company Profile
  companyName        String  @unique @map("company_name")
  registrationNumber String  @unique @map("registration_number")
  vatNumber          String? @unique @map("vat_number")

  // Contact Information
  mainEmail String  @unique @map("main_email")
  mainPhone String  @map("main_phone")
  website   String?

  // Company Type
  companyType CompanyType @default(EXTERNAL) @map("company_type")
  isVerified  Boolean     @default(false) @map("is_verified")
  verifiedAt  DateTime?   @map("verified_at")
  verifiedBy  String?     @map("verified_by") // Admin user ID who verified

  // Operating Information
  operatingRegions String[] @map("operating_regions") // e.g., ["Sofia", "Plovdiv", "Varna"]
  specializations  String[] // Types of goods they transport
  fleetSize        Int      @default(0) @map("fleet_size")

  // Performance Metrics
  totalJobsCompleted Int    @default(0) @map("total_jobs_completed")
  averageRating      Float? @map("average_rating")
  onTimeDeliveryRate Float? @map("on_time_delivery_rate")

  // Financial
  creditLimit    Decimal? @map("credit_limit") @db.Decimal(10, 2)
  currentBalance Decimal? @map("current_balance") @db.Decimal(10, 2)

  // Relations
  admins        CompanyAdmin[]
  drivers       Driver[]
  trucks        Truck[]
  transportBids TransportBid[]
  transportJobs TransportJob[]
  documents     CompanyDocument[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyType])
  @@index([isVerified])
  @@map("transport_companies")
}

model CompanyAdmin {
  id String @id @default(cuid())

  // Link to User account
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Link to Company
  transportCompanyId String           @map("transport_company_id")
  transportCompany   TransportCompany @relation(fields: [transportCompanyId], references: [id], onDelete: Cascade)

  // Admin Level
  adminLevel AdminLevel @default(MANAGER) @map("admin_level")

  // Permissions
  canManageDrivers  Boolean @default(true) @map("can_manage_drivers")
  canManageFleet    Boolean @default(true) @map("can_manage_fleet")
  canSubmitBids     Boolean @default(true) @map("can_submit_bids")
  canManageFinances Boolean @default(false) @map("can_manage_finances")
  canViewReports    Boolean @default(true) @map("can_view_reports")

  // Activity
  lastActiveAt DateTime? @map("last_active_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, transportCompanyId])
  @@index([transportCompanyId])
  @@map("company_admins")
}

model Driver {
  id String @id @default(cuid())

  // Driver can be either internal or external
  driverType DriverType @map("driver_type")

  // For INTERNAL drivers - direct link to User
  userId String? @unique @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  // For EXTERNAL drivers - link to transport company
  transportCompanyId String?           @map("transport_company_id")
  transportCompany   TransportCompany? @relation(fields: [transportCompanyId], references: [id])

  // Driver Profile (for external drivers who don't have user accounts)
  email       String? @unique
  phoneNumber String? @unique @map("phone_number")
  firstName   String? @map("first_name")
  lastName    String? @map("last_name")

  // License & Compliance
  licenseNumber     String   @unique @map("license_number")
  licenseClass      String[] @map("license_class") // ["C", "C+E", "ADR"]
  licenseExpiryDate DateTime @map("license_expiry_date")

  // Medical & Safety
  medicalCertificateExpiry DateTime? @map("medical_certificate_expiry")
  lastSafetyTraining       DateTime? @map("last_safety_training")

  // Current Status
  status             DriverStatus @default(OFFLINE)
  isAvailable        Boolean      @default(false) @map("is_available")
  currentLocation    Json?        @map("current_location") // {lat, lng, timestamp, address}
  lastLocationUpdate DateTime?    @map("last_location_update")

  // Current Assignment
  currentJobId String?       @unique @map("current_job_id")
  currentJob   TransportJob? @relation("CurrentDriverJob", fields: [currentJobId], references: [id])

  // Performance
  totalJobs     Int    @default(0) @map("total_jobs")
  totalDistance Float  @default(0) @map("total_distance") // km
  averageRating Float? @map("average_rating")
  onTimeRate    Float? @map("on_time_rate")

  // Working Hours (simplified - full compliance tracking can be added later)
  weeklyHoursWorked Float     @default(0) @map("weekly_hours_worked")
  lastRestPeriod    DateTime? @map("last_rest_period")

  // Relations
  assignedTruck Truck?           @relation("CurrentDriver")
  jobHistory    TransportJob[]   @relation("DriverJobHistory")
  documents     DriverDocument[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([driverType])
  @@index([transportCompanyId])
  @@index([status])
  @@index([isAvailable])
  @@map("drivers")
}

model CompanyDocument {
  id String @id @default(cuid())

  transportCompanyId String           @map("transport_company_id")
  transportCompany   TransportCompany @relation(fields: [transportCompanyId], references: [id], onDelete: Cascade)

  // Document details
  documentType   CompanyDocumentType @map("document_type")
  documentNumber String?             @map("document_number")
  documentUrl    String              @map("document_url") // Cloudinary URL

  // Validity
  issuedDate DateTime? @map("issued_date")
  expiryDate DateTime? @map("expiry_date")

  // Verification
  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")
  verifiedBy String?   @map("verified_by") // Admin user ID

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([transportCompanyId])
  @@index([documentType])
  @@map("company_documents")
}

model DriverDocument {
  id String @id @default(cuid())

  driverId String @map("driver_id")
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  // Document details
  documentType   DriverDocumentType @map("document_type")
  documentNumber String?            @map("document_number")
  documentUrl    String             @map("document_url") // Cloudinary URL

  // Validity
  issuedDate DateTime? @map("issued_date")
  expiryDate DateTime? @map("expiry_date")

  // Verification
  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")
  verifiedBy String?   @map("verified_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([driverId])
  @@index([documentType])
  @@map("driver_documents")
}

// ==================== NEW TRADE OPERATION ENUMS ====================

enum TradePhase {
  INITIATION
  SELLER_MATCHING
  SELLER_NEGOTIATION
  INSPECTION_PENDING
  TRANSPORT_MATCHING
  TRANSPORT_BIDDING
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

enum TradeStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  DISPUTED
}

enum SellerStatus {
  INVITED
  NEGOTIATING
  ACCEPTED
  REJECTED
  CONFIRMED
  WITHDRAWN
  FAILED_INSPECTION
}

enum TransporterStatus {
  INVITED
  BIDDING
  SELECTED
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum NegotiationStatus {
  PENDING // Initial offer sent, awaiting response
  ACCEPTED // Seller accepted the offer
  REJECTED // Seller rejected the offer
  COUNTERED // Seller made a counter-offer
  EXPIRED // 48 hours passed without response
  WITHDRAWN // Admin cancelled the offer
}

enum OfferParty {
  BUYER
  SELLER
  PLATFORM
}

enum OfferResponse {
  ACCEPTED
  REJECTED
  COUNTERED
}

enum InspectionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InspectionStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum TransportRequestStatus {
  OPEN // Accepting bids
  BIDDING // Active bidding period
  EVALUATING // Admin reviewing bids
  ASSIGNED // Transporter selected
  IN_PROGRESS // Transport started
  COMPLETED // Delivery completed
  CANCELLED // Request cancelled
}

enum UrgencyLevel {
  STANDARD // Normal timeline
  URGENT // Fast delivery needed
  EXPRESS // Same day/next day
  EMERGENCY // Critical emergency transport
}

enum TransportJobStatus {
  ASSIGNED // Job assigned to transporter
  STARTED // Transporter started journey
  PICKING_UP // Currently at pickup locations
  IN_TRANSIT // Transporting goods
  DELIVERING // At delivery location
  COMPLETED // Successfully delivered
  DELAYED // Behind schedule
  CANCELLED // Job cancelled
}

// ==================== TRANSPORT COMPANY & DRIVER MANAGEMENT ENUMS ====================

enum CompanyType {
  INTERNAL // Agro-Trade's own fleet
  EXTERNAL // Partner transport companies
}

enum DriverType {
  INTERNAL // Agro-Trade employee drivers
  EXTERNAL // Drivers from partner companies
}

enum AdminLevel {
  OWNER // Company owner
  MANAGER // Fleet manager
  DISPATCHER // Can assign drivers
  VIEWER // Read-only access
}

enum OwnerType {
  AGROTRADE // Owned by Agro-Trade
  COMPANY // Owned by transport company
  INDIVIDUAL // Owner-operator
}

enum DriverStatus {
  OFFLINE
  AVAILABLE
  ON_BREAK
  ASSIGNED
  EN_ROUTE
  AT_PICKUP
  IN_TRANSIT
  AT_DELIVERY
  COMPLETED
