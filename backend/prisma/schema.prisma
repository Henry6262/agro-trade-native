generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                     @id @default(cuid())
  email                     String                     @unique
  password                  String?
  name                      String?
  phoneNumber               String?                    @unique @map("phone_number")
  role                      UserRole                   @default(BUYER)
  isActive                  Boolean                    @default(true) @map("is_active")
  isEmailVerified           Boolean                    @default(false) @map("is_email_verified")
  isPhoneVerified           Boolean                    @default(false) @map("is_phone_verified")
  onboardingCompleted       Boolean                    @default(false) @map("onboarding_completed")
  lastLogin                 DateTime?                  @map("last_login")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  pushToken                 String?                    @map("push_token")
  addresses                 Address[]
  buyListings               BuyListing[]               @relation("BuyerListings")
  company                   Company?
  companyAdmin              CompanyAdmin?
  driverProfile             Driver?
  inspectionAssignments     InspectionRequest[]        @relation("InspectorAssignments")
  investmentPositions       InvestmentPosition[]
  profitEstimations         ProfitEstimation[]
  saleListings              SaleListing[]              @relation("SellerListings")
  tradeNotes                TradeNote[]
  tradeOperationsManaged    TradeOperation[]           @relation("TradeAdmin")
  tradeSellers              TradeSeller[]
  tradeStateChanges         TradeStateHistory[]
  tradeTransporters         TradeTransporter[]
  transportBids             TransportBid[]
  transportCostCalculations TransportCostCalculation[]
  transportJobs             TransportJob[]
  trucks                    Truck[]
  investmentPreference      UserInvestmentPreference?
  plantationRounds          PlantationRound[] @relation("SellerPlantationRounds")
  plantationNfts            PlantationNft[]   @relation("InvestorPlantationNfts")

  @@index([email])
  @@index([role])
  @@map("users")
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String   @db.VarChar(20)
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([phone, used, expiresAt])
  @@map("phone_otps")
}

model Company {
  id                 String    @id @default(cuid())
  userId             String    @unique @map("user_id")
  legalName          String    @map("legal_name")
  registrationNumber String?   @map("registration_number")
  vatNumber          String?   @map("vat_number")
  phoneNumber        String?   @map("phone_number")
  email              String?
  website            String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  addresses          Address[]
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("companies")
}

model Address {
  id           String        @id @default(cuid())
  userId       String?       @map("user_id")
  companyId    String?       @map("company_id")
  addressType  AddressType   @map("address_type")
  label        String?
  street       String?
  cityId       String?       @map("city_id")
  postalCode   String?       @map("postal_code")
  country      String?
  latitude     Float?
  longitude    Float?
  isDefault    Boolean       @default(false) @map("is_default")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  city         City?         @relation(fields: [cityId], references: [id])
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyListings  BuyListing[]  @relation("DeliveryAddress")
  saleListings SaleListing[] @relation("ListingAddress")

  @@index([userId])
  @@index([companyId])
  @@map("addresses")
}

model Region {
  id        String   @id @default(cuid())
  name      String
  country   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  cities    City[]

  @@unique([name, country])
  @@index([country])
  @@map("regions")
}

model City {
  id             String          @id @default(cuid())
  name           String
  regionId       String          @map("region_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  addresses      Address[]
  region         Region          @relation(fields: [regionId], references: [id], onDelete: Cascade)
  regionalPrices RegionalPrice[]

  @@unique([name, regionId])
  @@index([regionId])
  @@map("cities")
}

model Product {
  id                     String                @id @default(cuid())
  category               ProductCategory       @unique
  name                   String                @unique
  displayName            String                @map("display_name")
  description            String?
  image                  String?
  harvestSeason          String?               @map("harvest_season")
  storageRecommendations String?               @map("storage_recommendations")
  priceRangeMin          Decimal?              @map("price_range_min") @db.Decimal(10, 2)
  priceRangeMax          Decimal?              @map("price_range_max") @db.Decimal(10, 2)
  defaultUnit            ProductUnit           @default(TON) @map("default_unit")
  isActive               Boolean               @default(true) @map("is_active")
  sortOrder              Int?                  @map("sort_order")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  commodityRegistryId    String?               @map("commodity_registry_id")
  buyListings            BuyListing[]
  specTemplates          ProductSpecTemplate[]
  commodityRegistry      CommodityRegistry?    @relation(fields: [commodityRegistryId], references: [id])
  regionalPrices         RegionalPrice[]
  saleListings           SaleListing[]

  @@index([category])
  @@index([isActive])
  @@map("products")
}

model SpecificationType {
  id                   String                @id @default(cuid())
  code                 String                @unique
  name                 String
  unit                 String?
  dataType             DataType
  enumOptions          Json?
  minValue             Float?
  maxValue             Float?
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  listingSpecs         ListingSpec[]
  productSpecTemplates ProductSpecTemplate[]

  @@map("specification_types")
}

model ProductSpecTemplate {
  id                String            @id @default(cuid())
  productId         String            @map("product_id")
  specTypeId        String            @map("spec_type_id")
  importance        Importance
  displayOrder      Int               @default(0) @map("display_order")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  specificationType SpecificationType @relation(fields: [specTypeId], references: [id])

  @@unique([productId, specTypeId])
  @@index([productId])
  @@map("product_spec_templates")
}

model SaleListing {
  id                 String              @id @default(cuid())
  productId          String              @map("product_id")
  sellerId           String              @map("seller_id")
  addressId          String?             @map("address_id")
  quantity           Decimal             @db.Decimal(10, 2)
  unit               ProductUnit         @default(TON)
  askingPrice        Decimal?            @map("asking_price") @db.Decimal(10, 2)
  harvestDate        DateTime?           @map("harvest_date")
  qualityScore       Int?                @map("quality_score")
  qualityGrade       String?             @map("quality_grade")
  status             ListingStatus       @default(ACTIVE)
  viewCount          Int                 @default(0) @map("view_count")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  inspectionRequests InspectionRequest[]
  specifications     ListingSpec[]
  offers             Offer[]
  address            Address?            @relation("ListingAddress", fields: [addressId], references: [id])
  product            Product             @relation(fields: [productId], references: [id])
  seller             User                @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  tradeSellers       TradeSeller[]

  @@index([sellerId])
  @@index([productId])
  @@index([addressId])
  @@index([status])
  @@map("sale_listings")
}

model BuyListing {
  id                String          @id @default(cuid())
  productId         String          @map("product_id")
  buyerId           String          @map("buyer_id")
  deliveryAddressId String?         @map("delivery_address_id")
  quantity          Decimal         @db.Decimal(10, 2)
  unit              ProductUnit     @default(TON)
  maxPricePerUnit   Decimal?        @map("max_price_per_unit") @db.Decimal(10, 2)
  neededBy          DateTime?       @map("needed_by")
  status            RequestStatus   @default(ACTIVE)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  buyer             User            @relation("BuyerListings", fields: [buyerId], references: [id], onDelete: Cascade)
  deliveryAddress   Address?        @relation("DeliveryAddress", fields: [deliveryAddressId], references: [id])
  product           Product         @relation(fields: [productId], references: [id])
  specifications    ListingSpec[]
  offers            Offer[]
  tradeOperation    TradeOperation?

  @@index([buyerId])
  @@index([productId])
  @@index([deliveryAddressId])
  @@index([status])
  @@map("buy_listings")
}

model ListingSpec {
  id                     String            @id @default(cuid())
  saleListingId          String?           @map("sale_listing_id")
  buyListingId           String?           @map("buy_listing_id")
  specTypeId             String            @map("spec_type_id")
  valueNumber            Float?            @map("value_number")
  valueText              String?           @map("value_text")
  valueBool              Boolean?          @map("value_bool")
  minValue               Float?            @map("min_value")
  maxValue               Float?            @map("max_value")
  qualityImpact          QualityImpact?    @map("quality_impact")
  strictness             Strictness?
  priceAdjustmentPerUnit Decimal?          @map("price_adjustment_per_unit") @db.Decimal(10, 2)
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  buyListing             BuyListing?       @relation(fields: [buyListingId], references: [id], onDelete: Cascade)
  saleListing            SaleListing?      @relation(fields: [saleListingId], references: [id], onDelete: Cascade)
  specificationType      SpecificationType @relation(fields: [specTypeId], references: [id])

  @@unique([saleListingId, specTypeId])
  @@unique([buyListingId, specTypeId])
  @@index([saleListingId])
  @@index([buyListingId])
  @@map("listing_specs")
}

model Offer {
  id                String       @id @default(cuid())
  saleListingId     String?      @map("sale_listing_id")
  buyListingId      String?      @map("buy_listing_id")
  offeredPrice      Decimal      @map("offered_price") @db.Decimal(10, 2)
  quantity          Decimal      @db.Decimal(10, 2)
  unit              ProductUnit  @default(TON)
  matchScore        Int          @map("match_score")
  matchDetails      Json?        @map("match_details")
  basePrice         Decimal      @map("base_price") @db.Decimal(10, 2)
  qualityAdjustment Decimal?     @map("quality_adjustment") @db.Decimal(10, 2)
  quantityDiscount  Decimal?     @map("quantity_discount") @db.Decimal(10, 2)
  transportCost     Decimal?     @map("transport_cost") @db.Decimal(10, 2)
  finalPrice        Decimal      @map("final_price") @db.Decimal(10, 2)
  validUntil        DateTime     @map("valid_until")
  deliveryTerms     String?      @map("delivery_terms")
  paymentTerms      String?      @map("payment_terms")
  status            OfferStatus  @default(PENDING)
  rejectionReason   String?      @map("rejection_reason")
  createdBy         OfferCreator @map("created_by")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  buyListing        BuyListing?  @relation(fields: [buyListingId], references: [id], onDelete: Cascade)
  saleListing       SaleListing? @relation(fields: [saleListingId], references: [id], onDelete: Cascade)

  @@index([saleListingId])
  @@index([buyListingId])
  @@index([status])
  @@map("offers")
}

model RegionalPrice {
  id           String      @id @default(cuid())
  cityId       String      @map("city_id")
  productId    String      @map("product_id")
  pricePerUnit Decimal     @map("price_per_unit") @db.Decimal(10, 2)
  currency     String      @default("EUR")
  unit         ProductUnit @default(TON)
  lastUpdated  DateTime    @default(now()) @map("last_updated")
  city         City        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cityId, productId])
  @@index([cityId])
  @@index([productId])
  @@map("regional_prices")
}

model Truck {
  id                 String             @id @default(cuid())
  ownerId            String             @map("owner_id")
  ownerType          OwnerType          @default(INDIVIDUAL) @map("owner_type")
  transportCompanyId String?            @map("transport_company_id")
  currentDriverId    String?            @unique @map("current_driver_id")
  plateNumber        String             @unique @map("plate_number")
  capacity           Float
  unit               ProductUnit        @default(TON)
  type               TruckType
  currentLocation    String?            @map("current_location")
  latitude           Float?
  longitude          Float?
  isAvailable        Boolean            @default(true) @map("is_available")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  tradeTransporters  TradeTransporter[]
  transportBids      TransportBid[]
  currentDriver      Driver?            @relation("CurrentDriver", fields: [currentDriverId], references: [id])
  owner              User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  transportCompany   TransportCompany?  @relation(fields: [transportCompanyId], references: [id])

  @@index([ownerId])
  @@map("trucks")
}

model TradeOperation {
  id                        String                     @id @default(cuid())
  operationNumber           String                     @unique @map("operation_number")
  adminId                   String                     @map("admin_id")
  buyListingId              String                     @unique @map("buy_listing_id")
  phase                     TradePhase                 @default(INITIATION)
  status                    TradeStatus                @default(ACTIVE)
  currency                  String                     @default("EUR")
  totalPurchaseCost         Decimal?                   @map("total_purchase_cost") @db.Decimal(10, 2)
  avgPurchasePrice          Decimal?                   @map("avg_purchase_price") @db.Decimal(10, 2)
  sellingPrice              Decimal?                   @map("selling_price") @db.Decimal(10, 2)
  totalRevenue              Decimal?                   @map("total_revenue") @db.Decimal(10, 2)
  estimatedTransportCost    Decimal?                   @map("estimated_transport_cost") @db.Decimal(10, 2)
  actualTransportCost       Decimal?                   @map("actual_transport_cost") @db.Decimal(10, 2)
  totalDistanceKm           Float?                     @map("total_distance_km")
  estimatedProfit           Decimal?                   @map("estimated_profit") @db.Decimal(10, 2)
  actualProfit              Decimal?                   @map("actual_profit") @db.Decimal(10, 2)
  profitMargin              Float?                     @map("profit_margin")
  initiatedAt               DateTime                   @default(now()) @map("initiated_at")
  completedAt               DateTime?                  @map("completed_at")
  metadata                  Json?
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  incoterm                  Incoterm?                  @default(DDP)
  inspections               InspectionRequest[]
  investmentPositions       InvestmentPosition[]
  negotiations              OfferNegotiation[]
  profitEstimations         ProfitEstimation[]
  tradeEvents               TradeEvent[]
  notes                     TradeNote[]
  admin                     User                       @relation("TradeAdmin", fields: [adminId], references: [id])
  buyListing                BuyListing                 @relation(fields: [buyListingId], references: [id])
  sellers                   TradeSeller[]
  stateHistory              TradeStateHistory[]
  transporters              TradeTransporter[]
  transportBids             TransportBid[]
  transportCostCalculations TransportCostCalculation[]
  transportJobs             TransportJob[]
  transportRequest          TransportRequest?

  @@index([adminId])
  @@index([buyListingId])
  @@index([phase])
  @@index([status])
  @@index([adminId, status])
  @@index([status, phase])
  @@index([createdAt])
  @@map("trade_operations")
}

model TradeSeller {
  id                String            @id @default(cuid())
  tradeOperationId  String            @map("trade_operation_id")
  sellerId          String            @map("seller_id")
  saleListingId     String            @map("sale_listing_id")
  requestedQuantity Decimal           @map("requested_quantity") @db.Decimal(10, 2)
  offeredQuantity   Decimal           @map("offered_quantity") @db.Decimal(10, 2)
  agreedQuantity    Decimal?          @map("agreed_quantity") @db.Decimal(10, 2)
  unit              ProductUnit       @default(TON)
  agreedPrice       Decimal?          @map("agreed_price") @db.Decimal(10, 2)
  isVerified        Boolean           @default(false) @map("is_verified")
  matchScore        Int?              @map("match_score")
  status            SellerStatus      @default(INVITED)
  joinedAt          DateTime          @default(now()) @map("joined_at")
  confirmedAt       DateTime?         @map("confirmed_at")
  negotiation       OfferNegotiation?
  saleListing       SaleListing       @relation(fields: [saleListingId], references: [id])
  seller            User              @relation(fields: [sellerId], references: [id])
  tradeOperation    TradeOperation    @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  @@unique([tradeOperationId, saleListingId])
  @@index([tradeOperationId])
  @@index([sellerId])
  @@index([saleListingId])
  @@index([status])
  @@map("trade_sellers")
}

model TradeTransporter {
  id                String            @id @default(cuid())
  tradeOperationId  String            @map("trade_operation_id")
  transporterId     String            @map("transporter_id")
  pickupSellerId    String?           @map("pickup_seller_id")
  route             Json?
  estimatedDistance Float?            @map("estimated_distance")
  estimatedDuration Int?              @map("estimated_duration")
  agreedPrice       Decimal?          @map("agreed_price") @db.Decimal(10, 2)
  vehicleId         String?           @map("vehicle_id")
  status            TransporterStatus @default(INVITED)
  assignedAt        DateTime          @default(now()) @map("assigned_at")
  confirmedAt       DateTime?         @map("confirmed_at")
  deliveredAt       DateTime?         @map("delivered_at")
  tradeOperation    TradeOperation    @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  transporter       User              @relation(fields: [transporterId], references: [id])
  vehicle           Truck?            @relation(fields: [vehicleId], references: [id])

  @@unique([tradeOperationId, transporterId])
  @@index([tradeOperationId])
  @@index([transporterId])
  @@index([status])
  @@map("trade_transporters")
}

model OfferNegotiation {
  id               String            @id @default(cuid())
  tradeOperationId String            @map("trade_operation_id")
  tradeSellerId    String            @unique @map("trade_seller_id")
  status           NegotiationStatus @default(PENDING)
  currentOffer     Json              @map("current_offer")
  counterOffer     Json?             @map("counter_offer")
  offerHistory     Json[]            @default([]) @map("offer_history")
  finalPrice       Decimal?          @map("final_price") @db.Decimal(10, 2)
  finalQuantity    Decimal?          @map("final_quantity") @db.Decimal(10, 2)
  unit             ProductUnit       @default(TON)
  startedAt        DateTime          @default(now()) @map("started_at")
  respondedAt      DateTime?         @map("responded_at")
  concludedAt      DateTime?         @map("concluded_at")
  expiresAt        DateTime          @map("expires_at")
  tradeOperation   TradeOperation    @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)
  tradeSeller      TradeSeller       @relation(fields: [tradeSellerId], references: [id])
  offerRounds      OfferRound[]

  @@index([tradeOperationId])
  @@index([tradeSellerId])
  @@index([status])
  @@index([expiresAt])
  @@map("offer_negotiations")
}

model OfferRound {
  id            String           @id @default(cuid())
  negotiationId String           @map("negotiation_id")
  roundNumber   Int              @map("round_number")
  offeredBy     OfferParty       @map("offered_by")
  price         Decimal          @db.Decimal(10, 2)
  quantity      Decimal          @db.Decimal(10, 2)
  terms         String?
  response      OfferResponse?
  responseNote  String?          @map("response_note")
  createdAt     DateTime         @default(now()) @map("created_at")
  respondedAt   DateTime?        @map("responded_at")
  negotiation   OfferNegotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@unique([negotiationId, roundNumber])
  @@index([negotiationId])
  @@map("offer_rounds")
}

model InspectionRequest {
  id                 String             @id @default(cuid())
  tradeOperationId   String?            @map("trade_operation_id")
  saleListingId      String             @map("sale_listing_id")
  inspectorId        String?            @map("inspector_id")
  priority           InspectionPriority @default(MEDIUM)
  requestedDate      DateTime?          @map("requested_date")
  scheduledDate      DateTime?          @map("scheduled_date")
  completedDate      DateTime?          @map("completed_date")
  latitude           Float
  longitude          Float
  address            String?
  status             InspectionStatus   @default(PENDING)
  qualityScore       Int?               @map("quality_score")
  verificationResult Json?              @map("verification_result")
  notes              String?
  photos             String[]
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  inspector          User?              @relation("InspectorAssignments", fields: [inspectorId], references: [id])
  saleListing        SaleListing        @relation(fields: [saleListingId], references: [id])
  tradeOperation     TradeOperation?    @relation(fields: [tradeOperationId], references: [id])

  @@index([tradeOperationId])
  @@index([saleListingId])
  @@index([inspectorId])
  @@index([status])
  @@index([priority])
  @@map("inspection_requests")
}

model TransportRequest {
  id                  String                 @id @default(cuid())
  requestNumber       String                 @unique @map("request_number")
  tradeOperationId    String                 @unique @map("trade_operation_id")
  totalWeight         Float                  @map("total_weight")
  requiredVehicleType TruckType?             @map("required_vehicle_type")
  specialRequirements String[]               @map("special_requirements")
  pickupPoints        Json                   @map("pickup_points")
  deliveryPoint       Json                   @map("delivery_point")
  estimatedDistance   Float?                 @map("estimated_distance")
  pickupWindowStart   DateTime?              @map("pickup_window_start")
  pickupWindowEnd     DateTime?              @map("pickup_window_end")
  deliveryDeadline    DateTime?              @map("delivery_deadline")
  urgencyLevel        UrgencyLevel           @default(STANDARD) @map("urgency_level")
  status              TransportRequestStatus @default(OPEN)
  biddingDeadline     DateTime               @map("bidding_deadline")
  maxBudget           Decimal?               @map("max_budget") @db.Decimal(10, 2)
  selectedBidId       String?                @unique @map("selected_bid_id")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")
  cargoDescription    String?                @map("cargo_description")
  bids                TransportBid[]         @relation("RequestBids")
  transportJob        TransportJob?
  selectedBid         TransportBid?          @relation("SelectedBid", fields: [selectedBidId], references: [id])
  tradeOperation      TradeOperation         @relation(fields: [tradeOperationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([urgencyLevel])
  @@index([biddingDeadline])
  @@map("transport_requests")
}

model TransportBid {
  id                 String            @id @default(cuid())
  transportRequestId String            @map("transport_request_id")
  tradeOperationId   String            @map("trade_operation_id")
  transporterId      String            @map("transporter_id")
  transportCompanyId String?           @map("transport_company_id")
  bidAmount          Decimal           @map("bid_amount") @db.Decimal(10, 2)
  estimatedDuration  Int               @map("estimated_duration")
  vehicleType        TruckType         @map("vehicle_type")
  vehicleCapacity    Float             @map("vehicle_capacity")
  assignedTruckId    String?           @map("assigned_truck_id")
  specialEquipment   String[]          @map("special_equipment")
  insuranceCoverage  Decimal?          @map("insurance_coverage") @db.Decimal(10, 2)
  proposedRoute      Json?             @map("proposed_route")
  pickupSchedule     Json?             @map("pickup_schedule")
  status             BidStatus         @default(PENDING)
  submittedAt        DateTime          @default(now()) @map("submitted_at")
  expiresAt          DateTime          @map("expires_at")
  evaluatedAt        DateTime?         @map("evaluated_at")
  acceptedAt         DateTime?         @map("accepted_at")
