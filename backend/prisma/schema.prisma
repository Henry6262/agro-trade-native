// Simplified Agro Trade Schema - MVP User Onboarding
// Version: 3.0 (With Product Catalog and Multi-Base Support)
// Focus: User authentication, product catalog, multi-base operations, and trading listings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  FARMER
  BUYER
  TRANSPORTER
  ADMIN
}

enum BaseType {
  WAREHOUSE      // Storage facility for buyers/sellers
  SILO          // Grain storage for farmers/cooperatives
  DEPOT         // Distribution center
  OFFICE        // Administrative/procurement office
  PORT          // Port facility for export/import
  FACTORY       // Processing facility
  FARM          // Farm location
}

enum TruckType {
  FLATBED
  TANKER
  REEFER
  OTHER
}

enum ProductCategory {
  WHEAT
  CORN
  SUNFLOWER
  BARLEY
  OATS
  RAPESEED
  PEAS
  SOYBEAN_MEAL
  WHEAT_BRAN
  ALFALFA
  OTHER
}

enum ProductUnit {
  TON
  KG
}

enum ListingType {
  SELL
  BUY
}

enum ListingStatus {
  DRAFT
  ACTIVE
  RESERVED
  SOLD
  EXPIRED
  CANCELLED
}

enum ProductStatus {
  AVAILABLE
  OUT_OF_STOCK
  PENDING
}

enum DocumentType {
  ID_CARD
  BUSINESS_LICENSE
  VAT_CERT
  INSURANCE
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StockStatus {
  AVAILABLE
  RESERVED
  SOLD
  IN_TRANSIT
}

// ==================== CORE TABLES ====================

// 1. Users - Core authentication and identity
model User {
  id        String   @id @default(cuid())
  googleId  String?  @unique @map("google_id")
  email     String   @unique
  name      String?
  phone     String?
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  farmerProfile      FarmerProfile?
  buyerProfile       BuyerProfile?
  transporterProfile TransporterProfile?
  companyInfo        CompanyInfo?
  products           Product[]           @relation("FarmerProducts")
  trucks             Truck[]
  listings           ProductListing[]
  documents          KycDocument[]
  fleetVehicles      FleetVehicle[]
  bases              Base[]              // Multiple bases per user
  stocks             BaseStock[]         // Stock across all bases
  demands            BaseDemand[]        // Demand across all bases

  @@map("users")
}

// 2. Role-based Profiles (unchanged)
model FarmerProfile {
  userId         String  @id @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  farmName       String? @map("farm_name")
  locationAddress String? @map("location_address")
  locationLat    Float?  @map("location_lat")
  locationLng    Float?  @map("location_lng")
  businessId     String? @map("business_id")
  iban           String?
  certifications Json?
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("farmer_profiles")
}

model BuyerProfile {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String? @map("company_name")
  vatId           String? @map("vat_id")
  billingAddress  Json?   @map("billing_address")
  paymentMethod   Json?   @map("payment_method")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("buyer_profiles")
}

model TransporterProfile {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String? @map("company_name")
  licenseNumber   String? @map("license_number")
  baseLocationAddress String? @map("base_location_address")
  baseLocationLat Float?  @map("base_location_lat")
  baseLocationLng Float?  @map("base_location_lng")
  insuranceDocUrl String? @map("insurance_doc_url")
  iban            String?
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("transporter_profiles")
}

// Company Information for enhanced registration flow
model CompanyInfo {
  userId          String  @id @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName     String  @map("company_name")
  vatNumber       String? @map("vat_number")
  businessLicense String? @map("business_license")
  companyAddress  Json?   @map("company_address")
  website         String?
  establishedYear Int?    @map("established_year")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("company_info")
}

// ==================== MULTI-BASE MANAGEMENT ====================

// Base/Depot/Warehouse management for all user types
model Base {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Base information
  name            String    // e.g., "Silo Plovdiv", "Sofia Warehouse"
  code            String?   // Internal code like "SPL-01"
  type            BaseType
  isPrimary       Boolean   @default(false) @map("is_primary")
  isActive        Boolean   @default(true) @map("is_active")
  
  // Location
  address         String
  city            String
  region          String?
  country         String    @default("Bulgaria")
  postalCode      String?   @map("postal_code")
  latitude        Float
  longitude       Float
  
  // Contact
  contactPerson   String?   @map("contact_person")
  contactPhone    String?   @map("contact_phone")
  contactEmail    String?   @map("contact_email")
  
  // Capacity and features
  storageCapacity Decimal?  @map("storage_capacity") @db.Decimal(10, 2) // in tons
  currentUsage    Decimal?  @map("current_usage") @db.Decimal(10, 2)    // in tons
  
  // Features (JSON array of strings)
  features        Json?     // ["Climate controlled", "Rail access", "24/7 security"]
  certifications  Json?     // ["ISO 9001", "HACCP"]
  
  // Operating hours
  operatingHours  Json?     @map("operating_hours") // {"monday": "08:00-18:00", ...}
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  stocks          BaseStock[]     // For sellers: what's in stock at this base
  demands         BaseDemand[]    // For buyers: what's needed at this base
  listings        ProductListing[] // Listings associated with this base
  
  @@unique([userId, code])
  @@index([userId])
  @@index([isActive])
  @@index([latitude, longitude])
  @@map("bases")
}

// Stock management per base (for sellers)
model BaseStock {
  id              String          @id @default(cuid())
  baseId          String          @map("base_id")
  base            Base            @relation(fields: [baseId], references: [id], onDelete: Cascade)
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String          @map("product_id")
  product         ProductCatalog  @relation(fields: [productId], references: [id])
  
  // Stock details
  quantity        Decimal         @db.Decimal(10, 2) // Current quantity in stock
  unit            ProductUnit
  status          StockStatus     @default(AVAILABLE)
  
  // Quality and specifications
  qualityGrade    String?         @map("quality_grade")
  harvestDate     DateTime?       @map("harvest_date")
  expiryDate      DateTime?       @map("expiry_date")
  batchNumber     String?         @map("batch_number")
  
  // Storage details
  storageLocation String?         @map("storage_location") // Specific location within base
  temperature     Float?          // Current storage temperature
  humidity        Float?          // Current humidity level
  
  // Pricing (can vary by base)
  pricePerUnit    Decimal?        @map("price_per_unit") @db.Decimal(10, 2)
  
  // Metadata
  notes           String?         @db.Text
  lastInspection  DateTime?       @map("last_inspection")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  @@unique([baseId, productId, batchNumber])
  @@index([baseId])
  @@index([productId])
  @@index([status])
  @@map("base_stocks")
}

// Demand management per base (for buyers)
model BaseDemand {
  id              String          @id @default(cuid())
  baseId          String          @map("base_id")
  base            Base            @relation(fields: [baseId], references: [id], onDelete: Cascade)
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String          @map("product_id")
  product         ProductCatalog  @relation(fields: [productId], references: [id])
  
  // Demand details
  requiredQuantity Decimal        @map("required_quantity") @db.Decimal(10, 2)
  unit            ProductUnit
  urgency         String?         // "immediate", "within_week", "within_month"
  
  // Requirements
  qualityGrade    String?         @map("quality_grade")
  specifications  Json?           // Specific requirements
  maxPricePerUnit Decimal?        @map("max_price_per_unit") @db.Decimal(10, 2)
  
  // Timeline
  neededBy        DateTime?       @map("needed_by")
  validUntil      DateTime?       @map("valid_until")
  
  // Fulfillment tracking
  fulfilledQuantity Decimal?      @map("fulfilled_quantity") @db.Decimal(10, 2)
  remainingQuantity Decimal?      @map("remaining_quantity") @db.Decimal(10, 2)
  
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  @@index([baseId])
  @@index([productId])
  @@map("base_demands")
}

// Enhanced fleet vehicle information for transporters
model FleetVehicle {
  id            String    @id @default(cuid())
  transporterId String    @map("transporter_id")
  transporter   User      @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  
  plateNumber   String    @map("plate_number")
  vehicleType   TruckType @map("vehicle_type")
  capacityKg    Int       @map("capacity_kg")
  year          Int?
  make          String?
  model         String?
  fuelType      String?   @map("fuel_type")
  active        Boolean   @default(true)
  
  registrationDoc String? @map("registration_doc")
  insuranceDoc    String? @map("insurance_doc")
  licenseDoc      String? @map("license_doc")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([transporterId])
  @@map("fleet_vehicles")
}

// 3. Assets
model Truck {
  id            String    @id @default(cuid())
  transporterId String    @map("transporter_id")
  transporter   User      @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  
  plateNumber   String    @map("plate_number")
  capacityKg    Int       @map("capacity_kg")
  type          TruckType
  active        Boolean   @default(true)
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([transporterId])
  @@map("trucks")
}

// ==================== PRODUCT STRUCTURE ====================

// Product Catalog - Master list of all tradeable products
model ProductCatalog {
  id              String          @id @default(cuid())
  category        ProductCategory @unique
  name            String
  displayName     String          @map("display_name")
  description     String?         @db.Text
  image           String?
  
  // Product details
  nutritionalInfo String?         @map("nutritional_info") @db.Text
  useCases        Json?           @map("use_cases")
  harvestSeason   String?         @map("harvest_season")
  storageRecommendations String?  @map("storage_recommendations") @db.Text
  
  // Pricing guidance
  priceRangeMin   Decimal?        @map("price_range_min") @db.Decimal(10, 2)
  priceRangeMax   Decimal?        @map("price_range_max") @db.Decimal(10, 2)
  defaultUnit     ProductUnit     @default(TON) @map("default_unit")
  
  // Quality specifications
  qualityGrades   Json?           @map("quality_grades")
  certifications  Json?
  specifications  Json?
  
  // Meta
  isActive        Boolean         @default(true) @map("is_active")
  sortOrder       Int             @default(0) @map("sort_order")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  // Relations
  listings        ProductListing[]
  stocks          BaseStock[]
  demands         BaseDemand[]
  
  @@index([isActive])
  @@index([sortOrder])
  @@map("product_catalog")
}

// Product - Simple product model for farmers (backwards compatibility)
model Product {
  id            String          @id @default(cuid())
  farmerId      String          @map("farmer_id")
  farmer        User            @relation("FarmerProducts", fields: [farmerId], references: [id], onDelete: Cascade)
  
  category      ProductCategory
  name          String
  description   String?         @db.Text
  quantity      Decimal         @db.Decimal(10, 2)
  unit          ProductUnit     @default(TON)
  pricePerUnit  Decimal         @map("price_per_unit") @db.Decimal(10, 2)
  
  location      String?
  harvestDate   DateTime?       @map("harvest_date")
  
  status        ProductStatus   @default(AVAILABLE)
  
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  
  @@index([farmerId])
  @@index([category])
  @@index([status])
  @@map("products")
}

// Product Listing - Actual buy/sell orders from users
model ProductListing {
  id              String          @id @default(cuid())
  
  // Link to catalog and user
  productId       String          @map("product_id")
  product         ProductCatalog  @relation(fields: [productId], references: [id])
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // NEW: Link to specific base
  baseId          String?         @map("base_id")
  base            Base?           @relation(fields: [baseId], references: [id])
  
  // Listing details
  listingType     ListingType     @map("listing_type")
  title           String?
  description     String?         @db.Text
  
  // Quantity and pricing
  quantity        Decimal         @db.Decimal(10, 2)
  unit            ProductUnit
  pricePerUnit    Decimal         @map("price_per_unit") @db.Decimal(10, 2)
  totalValue      Decimal         @map("total_value") @db.Decimal(12, 2)
  negotiable      Boolean         @default(true)
  
  // Quality and specifications
  qualityGrade    String?         @map("quality_grade")
  certifications  Json?
  specifications  Json?
  
  // Location (can be base location or custom)
  locationAddress String?         @map("location_address")
  locationLat     Float?          @map("location_lat")
  locationLng     Float?          @map("location_lng")
  
  // Delivery options (NEW)
  deliveryOptions Json?           @map("delivery_options") // ["EXW", "FOB", "CIF", "DAP"]
  splitDelivery   Boolean         @default(false) @map("split_delivery") // Allow delivery to multiple bases
  minOrderQuantity Decimal?       @map("min_order_quantity") @db.Decimal(10, 2)
  
  // Availability
  availableFrom   DateTime?       @map("available_from")
  availableTo     DateTime?       @map("available_to")
  harvestDate     DateTime?       @map("harvest_date")
  deliveryBy      DateTime?       @map("delivery_by")
  
  // Status
  status          ListingStatus   @default(DRAFT)
  viewCount       Int             @default(0) @map("view_count")
  
  // Additional media
  images          Json?
  documents       Json?
  
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  expiresAt       DateTime?       @map("expires_at")
  
  @@index([userId])
  @@index([productId])
  @@index([baseId])
  @@index([listingType])
  @@index([status])
  @@index([createdAt])
  @@map("product_listings")
}

// 4. Compliance (unchanged)
model KycDocument {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  docType     DocumentType       @map("doc_type")
  docUrl      String             @map("doc_url")
  status      VerificationStatus @default(PENDING)
  submittedAt DateTime           @default(now()) @map("submitted_at")
  reviewedAt  DateTime?          @map("reviewed_at")
  reviewNotes String?            @map("review_notes")

  @@index([userId])
  @@index([status])
  @@map("kyc_documents")
}