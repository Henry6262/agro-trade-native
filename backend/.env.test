# Test Environment Variables
NODE_ENV=test
PORT=4001

# Database (dummy CI-safe value — real DB URL goes in GitHub Secrets only)
DATABASE_URL="postgresql://test:test@localhost:5432/test"

# JWT
JWT_SECRET="ci-test-secret-key"
JWT_EXPIRES_IN=1h

# API
API_PREFIX=api

# Logging
SUPPRESS_LOGS=false

# Test specific
TEST_TIMEOUT=30000
