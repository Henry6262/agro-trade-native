# Test Environment Variables
NODE_ENV=test
PORT=4001

# Database (using dev database for local testing - switch to test db for CI)
DATABASE_URL="postgresql://henry@localhost:5432/agro_trade_dev?schema=public"

# JWT
JWT_SECRET=test-jwt-secret-key-for-testing-only
