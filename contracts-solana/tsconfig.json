{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "lib": ["ES2022"],
    "outDir": "dist",
    "verbatimModuleSyntax": false
  },
  "include": ["programs/**/*", "tests/**/*", "app/**/*"],
  "exclude": ["node_modules", "target"]
}
