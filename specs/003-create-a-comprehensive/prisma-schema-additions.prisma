// ==================== NEW ENUMS ====================

enum TradePhase {
  INITIATION
  SELLER_MATCHING
  SELLER_NEGOTIATION
  INSPECTION_PENDING
  TRANSPORT_MATCHING
  TRANSPORT_BIDDING
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

enum TradeStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  DISPUTED
}

enum SellerStatus {
  INVITED
  NEGOTIATING
  ACCEPTED
  REJECTED
  CONFIRMED
  WITHDRAWN
}

enum TransporterStatus {
  INVITED
  BIDDING
  SELECTED
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum NegotiationStatus {
  ACTIVE
  AGREED
  FAILED
  EXPIRED
}

enum OfferParty {
  BUYER
  SELLER
  PLATFORM
}

enum OfferResponse {
  ACCEPTED
  REJECTED
  COUNTERED
}

enum InspectionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InspectionStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}