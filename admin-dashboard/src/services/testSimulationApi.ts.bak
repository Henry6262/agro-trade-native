/**
 * Test file to verify simulationApi integration with scenarioContext
 * Run this to ensure the API calls properly resolve context references
 */

import { simulationApi, scenarioContext } from './simulationApi';

async function testScenarioContext() {
  console.log('Testing simulationApi with scenarioContext integration...\n');

  try {
    // Simulate adding users to context
    console.log('1. Adding test users to context...');
    scenarioContext.addUser('FARMER', {
      id: 'farmer-123',
      email: 'farmer@test.com',
      role: 'FARMER',
      name: 'Test Farmer'
    });

    scenarioContext.addUser('BUYER', {
      id: 'buyer-456',
      email: 'buyer@test.com',
      role: 'BUYER',
      name: 'Test Buyer'
    });

    scenarioContext.addUser('TRANSPORTER', {
      id: 'transporter-789',
      email: 'transporter@test.com',
      role: 'TRANSPORTER',
      name: 'Test Transporter'
    });

    scenarioContext.addUser('INSPECTOR', {
      id: 'inspector-001',
      email: 'inspector@test.com',
      role: 'INSPECTOR',
      name: 'Test Inspector'
    });

    console.log('Users added. Context stats:', scenarioContext.getStats());

    // Test createSaleListing
    console.log('\n2. Testing createSaleListing with farmerIndex...');
    const testSaleListing = {
      farmerIndex: 0, // Should resolve to farmer-123
      productCategory: 'WHEAT',
      quantity: 100,
      pricePerUnit: 250,
      latitude: 12.34,
      longitude: 56.78
    };

    console.log('Input:', testSaleListing);
    // This would call the real API in production
    // For now, just showing how it resolves the farmer ID
    const farmer = scenarioContext.getUser('FARMER', 0);
    console.log('Resolved farmer ID:', farmer?.id);

    // Test createBuyListing
    console.log('\n3. Testing createBuyListing with buyerIndex...');
    const testBuyListing = {
      buyerIndex: 0, // Should resolve to buyer-456
      productCategory: 'WHEAT',
      quantity: 100,
      maxPricePerUnit: 300
    };

    console.log('Input:', testBuyListing);
    const buyer = scenarioContext.getUser('BUYER', 0);
    console.log('Resolved buyer ID:', buyer?.id);

    // Simulate adding entities
    console.log('\n4. Simulating entity additions...');
    scenarioContext.addEntity('saleListings', { id: 'sale-001', farmerId: 'farmer-123' });
    scenarioContext.addEntity('buyListings', { id: 'buy-001', buyerId: 'buyer-456' });
    scenarioContext.addEntity('tradeOperations', { id: 'trade-001' });
    scenarioContext.addEntity('negotiations', { id: 'nego-001' });

    // Test entity retrieval
    console.log('\n5. Testing entity retrieval...');
    const saleListing = scenarioContext.getEntity('saleListings', 0);
    console.log('Retrieved sale listing:', saleListing);

    const buyListing = scenarioContext.getEntity('buyListings', 0);
    console.log('Retrieved buy listing:', buyListing);

    const tradeOp = scenarioContext.getEntity('tradeOperations', 0);
    console.log('Retrieved trade operation:', tradeOp);

    // Test initiateNegotiation resolution
    console.log('\n6. Testing initiateNegotiation with indices...');
    const testNegotiation = {
      tradeOperationIndex: 0, // Should resolve to trade-001
      farmerIndex: 0,         // Should resolve to farmer-123
      saleListingIndex: 0,     // Should resolve to sale-001
      requestedQuantity: 50,
      offeredPrice: 260
    };

    console.log('Input:', testNegotiation);
    console.log('Would resolve to:');
    console.log('- Trade Operation ID:', scenarioContext.getEntity('tradeOperations', 0)?.id);
    console.log('- Farmer ID:', scenarioContext.getUser('FARMER', 0)?.id);
    console.log('- Sale Listing ID:', scenarioContext.getEntity('saleListings', 0)?.id);

    // Final stats
    console.log('\n7. Final context statistics:');
    console.log(scenarioContext.getStats());

    console.log('\n✅ Context integration test completed successfully!');
    console.log('\nThe simulationApi methods will now:');
    console.log('- Automatically resolve index references to actual IDs');
    console.log('- Store results in context for future reference');
    console.log('- Provide clear error messages when entities are not found');

  } catch (error) {
    console.error('❌ Test failed:', error);
  }
}

// Export for testing
export { testScenarioContext };

// Run test if this file is executed directly
if (require.main === module) {
  testScenarioContext();
}