# Dependencies
node_modules/
*/node_modules/

# Production builds
dist/
build/
*.build

# Environment files — block all .env variants except .example templates
.env
.env.*
!.env.example
!.env.test.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backend env files — explicit block
backend/.env
backend/.env.*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/
*.lcov

# TypeScript
*.tsbuildinfo

# Temporary files
tmp/
temp/

# Expo
.expo/
.playwright-mcp/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# Metro
.metro-health-check*

# Backend specific
backend/prisma/*.db
backend/prisma/*.db-journal
contracts-solana/target/

# Frontend specific
front-end/.expo/.worktrees/
.worktrees/
*.docx
.env.escrow

# Python build artifacts (voice-agent)
__pycache__/
*.py[cod]

# Large media — keep out of git, use external storage
recordings/
*.mp4
*.mov
